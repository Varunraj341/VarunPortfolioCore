    <script>
    /* ═══════════════ THEME */
        function toggleTheme() {
            const h = document.documentElement, b = document.getElementById('themeBtn');
            if (h.dataset.theme === 'dark') { h.dataset.theme = 'light'; b.innerHTML = '☀️ Light'; }
            else { h.dataset.theme = 'dark'; b.innerHTML = '🌙 Dark'; }
        }

        /* ═══════════════ MOBILE MENU */
        function toggleMenu() {
            document.getElementById('hamburger').classList.toggle('open');
            document.getElementById('mobileMenu').classList.toggle('open');
        }
        function closeMenu() {
            document.getElementById('hamburger').classList.remove('open');
            document.getElementById('mobileMenu').classList.remove('open');
        }

        /* ═══════════════ POPUP */
        function openPopup() {
            document.getElementById('popupOverlay').classList.add('open');
            document.body.style.overflow = 'hidden';
        }
        function closePopup() {
            document.getElementById('popupOverlay').classList.remove('open');
            document.body.style.overflow = '';
            setTimeout(() => {
                document.getElementById('popupForm').style.display = 'block';
                document.getElementById('successMsg').style.display = 'none';
            }, 400);
        }
        function closePopupOutside(e) {
            if (e.target === document.getElementById('popupOverlay')) closePopup();
        }
        function submitForm() {
            const name = document.getElementById('f-name').value.trim();
            const email = document.getElementById('f-email').value.trim();
            const msg = document.getElementById('f-msg').value.trim();
            if (!name || !email || !msg) {
                alert('Please fill Name, Email and Project Details.'); return;
            }
            document.getElementById('popupForm').style.display = 'none';
            document.getElementById('successMsg').style.display = 'block';
        }

        /* ═══════════════ 3D CANVAS */
        const cv = document.getElementById('bg-canvas');
        const cx = cv.getContext('2d');
        let W, H, pts = [], mouse = { x: null, y: null };
        function resize() { W = cv.width = window.innerWidth; H = cv.height = window.innerHeight; }
        resize();
        window.addEventListener('resize', () => { resize(); initPts(); });
        window.addEventListener('mousemove', e => { mouse.x = e.clientX; mouse.y = e.clientY; });
        window.addEventListener('touchmove', e => {
            mouse.x = e.touches[0].clientX; mouse.y = e.touches[0].clientY;
        }, { passive: true });

        class Pt {
            constructor() { this.reset(true); }
            reset(init) {
                this.ox = Math.random() * W; this.oy = Math.random() * H;
                this.x = this.ox; this.y = this.oy;
                this.z = init ? Math.random() * 900 + 50 : 950;
                this.vz = -(Math.random() * .7 + .2);
                this.r = Math.random() * 1.8 + .3;
                this.a = Math.random() * .5 + .15;
                this.col = Math.random() > .55 ? '0,212,255' : '139,92,246';
            }
            update() {
                this.z += this.vz;
                if (this.z < 1) { this.reset(false); return; }
                const fov = 900;
                this.sx = (this.ox - W / 2) * (fov / this.z) + W / 2;
                this.sy = (this.oy - H / 2) * (fov / this.z) + H / 2;
                this.sr = this.r * (fov / this.z) * 1.6;
                if (mouse.x != null) {
                    this.ox += (mouse.x - W / 2) * .00008;
                    this.oy += (mouse.y - H / 2) * .00008;
                }
                if (this.sx < -30 || this.sx > W + 30 || this.sy < -30 || this.sy > H + 30) this.reset(false);
            }
            draw() {
                const dark = document.documentElement.dataset.theme === 'dark';
                cx.beginPath();
                cx.arc(this.sx, this.sy, Math.max(.1, this.sr), 0, Math.PI * 2);
                cx.fillStyle = `rgba(${this.col},${dark ? this.a : this.a * .28})`;
                cx.fill();
            }
        }
        function drawNet() {
            const dark = document.documentElement.dataset.theme === 'dark';
            for (let i = 0; i < pts.length; i++) {
                for (let j = i + 1; j < pts.length; j++) {
                    const a = pts[i], b = pts[j];
                    const d = Math.hypot(a.sx - b.sx, a.sy - b.sy);
                    if (d < 115) {
                        cx.beginPath(); cx.moveTo(a.sx, a.sy); cx.lineTo(b.sx, b.sy);
                        cx.strokeStyle = `rgba(0,212,255,${(dark ? .1 : .035) * (1 - d / 115)})`;
                        cx.lineWidth = .55; cx.stroke();
                    }
                }
            }
        }
        function initPts() {
            pts = [];
            const n = Math.min(Math.floor(W * H / 10500), 140);
            for (let i = 0; i < n; i++)pts.push(new Pt());
        }
        initPts();
        (function loop() {
            cx.clearRect(0, 0, W, H);
            pts.forEach(p => { p.update(); p.draw(); });
            drawNet();
            requestAnimationFrame(loop);
        })();

        /* ═══════════════ SCROLL REVEAL */
        function checkReveal() {
            document.querySelectorAll('[data-reveal]:not(.revealed)').forEach(el => {
                const rect = el.getBoundingClientRect();
                if (rect.top < window.innerHeight * .9) {
                    const delay = parseInt(el.dataset.delay || 0);
                    setTimeout(() => el.classList.add('revealed'), delay);
                }
            });
        }
        window.addEventListener('scroll', checkReveal, { passive: true });
        checkReveal();

        /* ═══════════════ NAV ACTIVE */
        const allSecs = document.querySelectorAll('section[id]');
        const nls = document.querySelectorAll('.nav-center a');
        window.addEventListener('scroll', () => {
            let cur = '';
            allSecs.forEach(s => { if (scrollY >= s.offsetTop - 240) cur = s.id; });
            nls.forEach(a => {
                a.classList.toggle('active', a.getAttribute('href') === '#' + cur);
            });
        }, { passive: true });

      function submitForm() {

    var data = {
        Name: $("#f-name").val(),
        Phone: $("#f-phone").val(),
        Email: $("#f-email").val(),
        Type: $("#f-type").val(),
        Message: $("#f-msg").val()
    };

    // Validation
    if (!data.Name || !data.Email || !data.Message) {
        alert("Please fill required fields");
        return;
    }

    $("#loader").show();
    $(".submit-btn").prop("disabled", true).text("Sending...");

    $.ajax({
        url: '/Home/SendMail',
        type: 'POST',
        data: JSON.stringify(data),
        contentType: 'application/json; charset=utf-8',

        success: function (res) {
            $("#loader").hide();
            $(".submit-btn").prop("disabled", false).text("Send Message →");

            if (res.success) {
                $("#popupForm").hide();
                $("#successMsg").show();
            } else {
                alert("Mail send failed ❌");
            }
        },

        error: function () {
            $("#loader").hide();
            $(".submit-btn").prop("disabled", false).text("Send Message →");
            alert("Server error ❌");
        }
    });
}
