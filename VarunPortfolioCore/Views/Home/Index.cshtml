@{
    ViewData["Title"] = "Home Page";
}

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Varuntech</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/@@emailjs/browser@4/dist/email.min.js"></script>
<style>
/* ═══════════════════════════════════ TOKENS */
:root{
  --bg:#07070e;--surface:#0d0d1a;--card:#111122;--border:#1e1e35;
  --accent:#00d4ff;--accent2:#8b5cf6;--accent3:#10b981;
  --text:#d8ddf0;--muted:#55557a;--white:#ffffff;
  --nav:rgba(7,7,14,0.9);--glow:rgba(0,212,255,0.12);
  --shadow:0 24px 64px rgba(0,0,0,0.55);
  --r:10px;
}
[data-theme="light"]{
  --bg:#f0f2ff;--surface:#e5e8fa;--card:#ffffff;--border:#ccd2f0;
  --accent:#007ab8;--accent2:#6d28d9;--accent3:#059669;
  --text:#1a1b3a;--muted:#707098;--white:#0d0d22;
  --nav:rgba(240,242,255,0.93);--glow:rgba(0,122,184,0.08);
  --shadow:0 24px 64px rgba(0,0,0,0.1);
}
/* ═══════════════════════════════════ RESET */
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;font-size:16px;}
body{background:var(--bg);color:var(--text);font-family:'Plus Jakarta Sans',sans-serif;overflow-x:hidden;transition:background .4s,color .4s;}
a{text-decoration:none;color:inherit;}
img{display:block;}

/* ═══════════════════════════════════ CANVAS */
#bg-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;}

/* ═══════════════════════════════════ NAV */
nav{
  position:fixed;top:0;left:0;right:0;z-index:500;
  display:flex;justify-content:space-between;align-items:center;
  padding:.9rem 2rem;
  backdrop-filter:blur(28px);-webkit-backdrop-filter:blur(28px);
  background:var(--nav);border-bottom:1px solid var(--border);
  transition:all .4s;
}
.nav-logo{font-weight:800;font-size:.95rem;color:var(--accent);letter-spacing:.1em;}
.nav-center{display:flex;gap:1.6rem;list-style:none;}
.nav-center a{
  color:var(--muted);font-size:.7rem;letter-spacing:.1em;
  text-transform:uppercase;font-weight:700;transition:color .3s;
  position:relative;padding-bottom:2px;
}
.nav-center a::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:1px;
  background:var(--accent);transform:scaleX(0);transition:transform .3s;
}
.nav-center a:hover{color:var(--accent);}
.nav-center a:hover::after,.nav-center a.active::after{transform:scaleX(1);}
.nav-center a.active{color:var(--accent);}
.nav-right{display:flex;align-items:center;gap:.8rem;}
.theme-btn{
  background:var(--card);border:1px solid var(--border);color:var(--text);
  padding:.35rem .8rem;border-radius:20px;cursor:pointer;
  font-size:.72rem;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;
  transition:all .3s;display:flex;align-items:center;gap:.35rem;
}
.theme-btn:hover{border-color:var(--accent);color:var(--accent);}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px;}
.hamburger span{display:block;width:22px;height:2px;background:var(--text);border-radius:2px;transition:all .3s;}
.hamburger.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px);}
.hamburger.open span:nth-child(2){opacity:0;}
.hamburger.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px);}
.mobile-menu{
  display:none;position:fixed;top:56px;left:0;right:0;z-index:499;
  background:var(--nav);border-bottom:1px solid var(--border);
  backdrop-filter:blur(28px);padding:1rem 2rem;
  flex-direction:column;gap:.8rem;
}
.mobile-menu.open{display:flex;}
.mobile-menu a{color:var(--muted);font-size:.8rem;letter-spacing:.1em;text-transform:uppercase;font-weight:700;padding:.5rem 0;border-bottom:1px solid var(--border);}

/* ═══════════════════════════════════ HERO */
#hero{
  min-height:100vh;display:flex;align-items:center;
  padding:0 2rem;position:relative;z-index:1;
  padding-top:5rem;
}
.hero-inner{max-width:820px;margin:0 auto;width:100%;}
.hero-tag{
  display:inline-flex;align-items:center;gap:.5rem;
  background:rgba(0,212,255,.07);border:1px solid rgba(0,212,255,.2);
  color:var(--accent);padding:.38rem 1rem;border-radius:30px;
  font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;font-weight:800;
  margin-bottom:1.6rem;
  opacity:0;transform:translateY(20px);
  animation:slideUp .7s ease .1s forwards;
}
.live-dot{width:7px;height:7px;background:var(--accent3);border-radius:50%;animation:livepulse 1.4s ease infinite;}
@@keyframes livepulse{0%,100%{box-shadow:0 0 0 0 rgba(16,185,129,.6);}50%{box-shadow:0 0 0 6px rgba(16,185,129,0);}}
.hero-name{
  font-weight:800;
  font-size:clamp(2.4rem,6vw,4.2rem);
  line-height:1.06;color:var(--white);margin-bottom:.9rem;
  opacity:0;transform:translateY(24px);
  animation:slideUp .7s ease .2s forwards;
}
.hero-name .g{
  background:linear-gradient(135deg,var(--accent) 0%,var(--accent2) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.hero-role{
  font-size:.82rem;color:var(--muted);margin-bottom:1.4rem;
  font-family:'JetBrains Mono',monospace;letter-spacing:.04em;
  opacity:0;transform:translateY(20px);animation:slideUp .7s ease .3s forwards;
}
.hero-desc{
  font-size:.88rem;color:var(--text);line-height:1.9;max-width:560px;
  margin-bottom:2.2rem;opacity:0;transform:translateY(20px);
  animation:slideUp .7s ease .4s forwards;
}
.hero-stats{
  display:flex;gap:1.5rem;flex-wrap:wrap;margin-bottom:2.4rem;
  opacity:0;transform:translateY(20px);animation:slideUp .7s ease .5s forwards;
}
.stat{text-align:center;}
.stat-num{font-weight:800;font-size:1.6rem;color:var(--accent);font-family:'Plus Jakarta Sans',sans-serif;line-height:1;}
.stat-lbl{font-size:.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-top:.2rem;}
.stat-divider{width:1px;background:var(--border);align-self:stretch;}
.hero-btns{
  display:flex;gap:.9rem;flex-wrap:wrap;
  opacity:0;transform:translateY(20px);animation:slideUp .7s ease .6s forwards;
}
@@keyframes slideUp{to{opacity:1;transform:translateY(0);}}

/* BUTTONS */
.btn-p,.btn-s{
  padding:.78rem 1.6rem;font-weight:700;font-size:.75rem;
  letter-spacing:.08em;text-transform:uppercase;border-radius:6px;
  transition:all .3s;display:inline-flex;align-items:center;gap:.5rem;
  cursor:pointer;border:none;
}
.btn-p{background:var(--accent);color:#000;}
.btn-p:hover{background:#fff;transform:translateY(-3px);box-shadow:0 14px 36px rgba(0,212,255,.35);}
.btn-s{background:transparent;color:var(--text);border:1px solid var(--border);}
.btn-s:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-3px);}

/* ═══════════════════════════════════ SECTIONS */
section{padding:5rem 2rem;position:relative;z-index:1;}
.sec-inner{max-width:1100px;margin:0 auto;}
.sec-lbl{
  font-size:.65rem;letter-spacing:.25em;text-transform:uppercase;
  color:var(--accent);margin-bottom:.5rem;font-weight:800;
  display:flex;align-items:center;gap:.7rem;font-family:'JetBrains Mono',monospace;
}
.sec-lbl::after{content:'';height:1px;width:36px;background:var(--accent);opacity:.4;}
.sec-title{font-weight:800;font-size:clamp(1.65rem,3.5vw,2.3rem);color:var(--white);margin-bottom:2.5rem;}

/* ═══════════════════════════════════ SKILLS */
#skills{background:var(--surface);}
.skills-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;}
@@media(max-width:900px){.skills-grid{grid-template-columns:repeat(2,1fr);}}
@@media(max-width:540px){.skills-grid{grid-template-columns:1fr;}}
.skill-card{
  background:var(--card);border:1px solid var(--border);border-radius:var(--r);
  padding:1.5rem;transition:all .35s;position:relative;overflow:hidden;
}
.skill-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--accent),var(--accent2));
  transform:scaleX(0);transform-origin:left;transition:transform .4s;
}
.skill-card:hover::before{transform:scaleX(1);}
.skill-card:hover{border-color:rgba(0,212,255,.22);transform:translateY(-5px);box-shadow:var(--shadow);}
.skill-cat{font-weight:700;font-size:.75rem;color:var(--accent);letter-spacing:.08em;text-transform:uppercase;margin-bottom:.9rem;}
.skill-tags{display:flex;flex-wrap:wrap;gap:.4rem;}
.tag{
  background:rgba(255,255,255,.04);border:1px solid var(--border);
  color:var(--text);padding:.24rem .65rem;border-radius:4px;font-size:.7rem;transition:all .2s;
}
[data-theme="light"] .tag{background:rgba(0,0,0,.04);}
.tag:hover{background:rgba(0,212,255,.1);border-color:var(--accent);color:var(--accent);}

/* ═══════════════════════════════════ EXPERIENCE */
.exp-timeline{position:relative;padding-left:2.2rem;}
.exp-timeline::before{
  content:'';position:absolute;left:0;top:8px;bottom:0;width:2px;
  background:linear-gradient(to bottom,var(--accent),var(--accent2),transparent);border-radius:2px;
}
.exp-item{
  position:relative;margin-bottom:1.6rem;background:var(--card);
  border:1px solid var(--border);border-radius:var(--r);padding:1.6rem;transition:all .35s;
}
.exp-item::before{
  content:'';position:absolute;left:-2.7rem;top:1.75rem;
  width:12px;height:12px;background:var(--accent);border-radius:50%;
  box-shadow:0 0 18px var(--accent);border:2px solid var(--bg);
  transition:transform .3s;
}
.exp-item:hover::before{transform:scale(1.3);}
.exp-item:hover{border-color:rgba(0,212,255,.22);transform:translateX(5px);box-shadow:var(--shadow);}
.exp-current{
  display:inline-flex;align-items:center;gap:.35rem;
  background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.2);
  color:var(--accent3);padding:.15rem .55rem;border-radius:20px;
  font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;font-weight:800;
  margin-bottom:.5rem;
}
.exp-company{font-weight:800;font-size:1.05rem;color:var(--white);margin-bottom:.15rem;}
.exp-role{color:var(--accent);font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;font-weight:700;margin-bottom:.35rem;}
.exp-date{color:var(--muted);font-size:.69rem;margin-bottom:.9rem;font-family:'JetBrains Mono',monospace;}
.exp-desc{font-size:.8rem;color:var(--muted);line-height:1.78;}
/* ═══════════════════════════════════ PROJECTS POPUP */
.proj-popup-overlay{
  display:none;position:fixed;inset:0;z-index:950;
  background:rgba(0,0,0,.82);backdrop-filter:blur(12px);
  align-items:center;justify-content:center;padding:1.5rem;
}
.proj-popup-overlay.open{display:flex;}
.proj-popup-box{
  background:var(--card);border:1px solid var(--border);border-radius:20px;
  padding:2.4rem;width:100%;max-width:860px;position:relative;
  animation:popIn .4s cubic-bezier(.34,1.56,.64,1) both;
  max-height:90vh;overflow-y:auto;
}
.proj-popup-close{
  position:absolute;top:1.2rem;right:1.2rem;background:var(--border);border:none;
  color:var(--text);width:32px;height:32px;border-radius:50%;cursor:pointer;
  font-size:1.1rem;display:flex;align-items:center;justify-content:center;
  transition:all .2s;z-index:2;
}
.proj-popup-close:hover{background:var(--accent);color:#000;}
.proj-popup-title{
  font-weight:800;font-size:1.5rem;color:var(--white);
  margin-bottom:.4rem;
}
.proj-popup-sub{font-size:.8rem;color:var(--muted);margin-bottom:2rem;}
.freelance-grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:1.2rem;
}
@@media(max-width:600px){.freelance-grid{grid-template-columns:1fr;}}
.freelance-card{
  background:var(--surface);border:1px solid var(--border);border-radius:14px;
  padding:1.8rem 1.5rem;display:flex;flex-direction:column;gap:.9rem;
  cursor:pointer;transition:all .35s;position:relative;overflow:hidden;
  text-decoration:none;color:inherit;
}
.freelance-card::before{
  content:'';position:absolute;inset:0;
  opacity:0;transition:opacity .35s;border-radius:14px;
}
.freelance-card:nth-child(1)::before{background:linear-gradient(135deg,rgba(0,212,255,.07),rgba(0,212,255,.02));}
.freelance-card:nth-child(2)::before{background:linear-gradient(135deg,rgba(236,72,153,.07),rgba(139,92,246,.04));}
.freelance-card:nth-child(3)::before{background:linear-gradient(135deg,rgba(16,185,129,.07),rgba(16,185,129,.02));}
.freelance-card:nth-child(4)::before{background:linear-gradient(135deg,rgba(245,158,11,.07),rgba(245,158,11,.02));}
.freelance-card:hover::before{opacity:1;}
.freelance-card:hover{transform:translateY(-6px);box-shadow:0 24px 64px rgba(0,0,0,.55);}
.freelance-card:nth-child(1):hover{border-color:rgba(0,212,255,.4);}
.freelance-card:nth-child(2):hover{border-color:rgba(236,72,153,.4);}
.freelance-card:nth-child(3):hover{border-color:rgba(16,185,129,.4);}
.freelance-card:nth-child(4):hover{border-color:rgba(245,158,11,.4);}
.fc-icon{font-size:2.4rem;line-height:1;}
.fc-title{font-weight:800;font-size:1.05rem;color:var(--white);}
.fc-desc{font-size:.76rem;color:var(--muted);line-height:1.72;flex:1;}
.fc-arrow{
  font-size:.75rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
  display:flex;align-items:center;gap:.4rem;margin-top:.3rem;
}
.freelance-card:nth-child(1) .fc-arrow{color:var(--accent);}
.freelance-card:nth-child(2) .fc-arrow{color:#ec4899;}
.freelance-card:nth-child(3) .fc-arrow{color:var(--accent3);}
.freelance-card:nth-child(4) .fc-arrow{color:#f59e0b;}
/* ═══════════════════════════════════ PROJECTS */
#projects{background:var(--surface);}
.projects-scroll-wrap{
  overflow-x:auto;scroll-snap-type:x mandatory;
  -webkit-overflow-scrolling:touch;
  display:flex;gap:1.1rem;
  padding-bottom:1.2rem;
  scrollbar-width:thin;scrollbar-color:var(--accent2) var(--border);
}
.projects-scroll-wrap::-webkit-scrollbar{height:4px;}
.projects-scroll-wrap::-webkit-scrollbar-track{background:var(--border);border-radius:2px;}
.projects-scroll-wrap::-webkit-scrollbar-thumb{background:var(--accent2);border-radius:2px;}
.project-card{
  flex:0 0 320px;scroll-snap-align:start;
  background:var(--card);border:1px solid var(--border);border-radius:var(--r);
  padding:1.7rem;display:flex;flex-direction:column;gap:.8rem;
  position:relative;overflow:hidden;transition:all .35s;
}
@@media(min-width:900px){
  .projects-scroll-wrap{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    overflow-x:visible;
  }
  .project-card{flex:unset;}
}
.project-card::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(0,212,255,.04),rgba(139,92,246,.04));
  opacity:0;transition:opacity .35s;
}
.project-card:hover::after{opacity:1;}
.project-card:hover{border-color:rgba(0,212,255,.22);transform:translateY(-6px);box-shadow:var(--shadow);}
.project-num{
  font-weight:800;font-size:2.5rem;color:rgba(0,212,255,.06);
  line-height:1;position:absolute;top:.9rem;right:1.2rem;
  font-family:'Plus Jakarta Sans',sans-serif;
}
.proj-badge{
  display:inline-flex;align-items:center;gap:.35rem;
  padding:.18rem .6rem;border-radius:20px;
  font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;font-weight:800;width:fit-content;
}
.b-bank{background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.2);color:var(--accent);}
.b-edu{background:rgba(139,92,246,.08);border:1px solid rgba(139,92,246,.2);color:#a78bfa;}
.b-ent{background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.2);color:var(--accent3);}
.b-sup{background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.2);color:#fbbf24;}
.b-hr{background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);color:#f87171;}
.project-title{font-weight:800;font-size:1.05rem;color:var(--white);}
.project-client{font-size:.68rem;color:var(--muted);font-family:'JetBrains Mono',monospace;}
.project-tech-line{
  font-size:.68rem;color:var(--accent2);font-family:'JetBrains Mono',monospace;
  font-weight:500;
}
.project-desc{font-size:.78rem;color:var(--muted);line-height:1.78;flex:1;}
.project-stack{display:flex;flex-wrap:wrap;gap:.35rem;margin-top:auto;}
.stack-tag{
  background:rgba(139,92,246,.09);border:1px solid rgba(139,92,246,.18);
  color:#a78bfa;padding:.18rem .55rem;border-radius:4px;font-size:.66rem;
}
.scroll-hint{
  text-align:center;margin-top:.7rem;color:var(--muted);
  font-size:.68rem;font-family:'JetBrains Mono',monospace;letter-spacing:.1em;
}
@@media(min-width:900px){.scroll-hint{display:none;}}

/* ═══════════════════════════════════ CONTACT */
.contact-wrap{display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:start;}
@@media(max-width:700px){.contact-wrap{grid-template-columns:1fr;}}
.contact-links{display:flex;flex-direction:column;gap:.9rem;}
.contact-item{
  display:flex;align-items:center;gap:.9rem;background:var(--card);
  border:1px solid var(--border);border-radius:var(--r);padding:1rem 1.3rem;
  cursor:pointer;transition:all .3s;color:var(--text);
}
.contact-item:hover{border-color:var(--accent);color:var(--accent);transform:translateX(5px);}
.contact-icon{
  width:38px;height:38px;background:rgba(0,212,255,.08);border-radius:7px;
  display:flex;align-items:center;justify-content:center;font-size:.95rem;flex-shrink:0;
}
.c-lbl{font-size:.62rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;font-weight:700;margin-bottom:.12rem;}
.c-val{font-size:.83rem;}
.hire-card{
  background:var(--card);border:1px solid var(--border);border-radius:var(--r);
  padding:2.2rem;text-align:center;position:relative;overflow:hidden;
}
.hire-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,212,255,.04),rgba(139,92,246,.05));}
.hire-card h3{font-weight:800;font-size:1.55rem;color:var(--white);margin-bottom:.7rem;position:relative;}
.hire-card p{color:var(--muted);font-size:.8rem;line-height:1.75;margin-bottom:1.8rem;position:relative;}

/* ═══════════════════════════════════ POPUP */
.popup-overlay{
  display:none;position:fixed;inset:0;z-index:900;
  background:rgba(0,0,0,.7);backdrop-filter:blur(8px);
  align-items:center;justify-content:center;padding:1rem;
}
.popup-overlay.open{display:flex;}
.popup-box{
  background:var(--card);border:1px solid var(--border);border-radius:16px;
  padding:2.2rem;width:100%;max-width:460px;position:relative;
  animation:popIn .35s cubic-bezier(.34,1.56,.64,1) both;
}
@@keyframes popIn{from{opacity:0;transform:scale(.85) translateY(20px);}to{opacity:1;transform:scale(1) translateY(0);}}
.popup-close{
  position:absolute;top:1rem;right:1rem;background:var(--border);border:none;
  color:var(--text);width:30px;height:30px;border-radius:50%;cursor:pointer;
  font-size:1rem;display:flex;align-items:center;justify-content:center;
  transition:all .2s;
}
.popup-close:hover{background:var(--accent);color:#000;}
.popup-title{font-weight:800;font-size:1.3rem;color:var(--white);margin-bottom:.4rem;}
.popup-sub{font-size:.78rem;color:var(--muted);margin-bottom:1.6rem;}
.form-group{margin-bottom:1rem;}
.form-group label{display:block;font-size:.68rem;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;font-weight:700;margin-bottom:.4rem;}
.form-group input,.form-group textarea,.form-group select{
  width:100%;background:var(--surface);border:1px solid var(--border);
  color:var(--text);padding:.7rem .9rem;border-radius:6px;font-size:.82rem;
  font-family:'Plus Jakarta Sans',sans-serif;transition:border .3s;outline:none;
}
.form-group input:focus,.form-group textarea:focus,.form-group select:focus{border-color:var(--accent);}
.form-group textarea{resize:vertical;min-height:90px;}
.form-group select option{background:var(--card);}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;}
.submit-btn{
  width:100%;background:var(--accent);color:#000;padding:.8rem;
  border:none;border-radius:6px;font-weight:800;font-size:.8rem;
  letter-spacing:.08em;text-transform:uppercase;cursor:pointer;transition:all .3s;
