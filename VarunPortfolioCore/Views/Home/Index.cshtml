/* ═══════════════════════════════════ FOOTER */
footer{
  border-top:1px solid var(--border);padding:1.6rem 2rem;
  display:flex;justify-content:space-between;align-items:center;
  color:var(--muted);font-size:.7rem;position:relative;z-index:1;flex-wrap:wrap;gap:.5rem;
