@{
    ViewData["Title"] = "Home Page";
}

<style>
@@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Poppins:wght@400;500;600;700;800&display=swap');
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{--g1:#0a5c28;--g2:#1a7a3c;--g3:#25a552;--g4:#e8f7ee;--or:#f47c20;--rd:#e53935;--gd:#f5c518;--tx:#1a1a1a;--tx2:#666;--tx3:#aaa;--bd:#e8e8e8;--bg:#f3f5f3;--wh:#fff;--r:12px;--sh:0 2px 10px rgba(0,0,0,0.08)}
body{font-family:'Poppins',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh}

/* ── HEADER ── */
.hdr{background:linear-gradient(155deg,#063d1a,#0f5c28,#1a7a3c);position:sticky;top:0;z-index:200;box-shadow:0 2px 14px rgba(0,0,0,0.22)}
.hdr-top{display:flex;align-items:center;gap:8px;padding:9px 12px}
.logo{display:flex;align-items:center;gap:7px;flex-shrink:0;cursor:pointer}
.logo-ring{width:40px;height:40px;border-radius:50%;background:#fff;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.2);animation:float3d 3.5s ease-in-out infinite;flex-shrink:0}
@@keyframes float3d{0%,100%{transform:perspective(60px) rotateY(0) translateY(0)}50%{transform:perspective(60px) rotateY(12deg) translateY(-3px)}}
.logo-ring img{width:100%;height:100%;object-fit:cover}
.logo-txt b{display:block;font-size:13px;font-weight:800;color:#fff;line-height:1.1}
.logo-txt span{font-size:9px;color:#9de3b4;font-weight:600;letter-spacing:1.5px;text-transform:uppercase}
.search-wrap{flex:1;min-width:0;position:relative}
.search-wrap input{width:100%;background:rgba(255,255,255,0.18);border:1.5px solid rgba(255,255,255,0.28);border-radius:22px;padding:8px 36px 8px 13px;font-size:13px;color:#fff;font-family:'Poppins',sans-serif;outline:none;transition:all .2s}
.search-wrap input::placeholder{color:rgba(255,255,255,0.58);font-size:12px}
.search-wrap input:focus{background:rgba(255,255,255,0.26);border-color:rgba(255,255,255,0.6)}
.search-icon{position:absolute;right:11px;top:50%;transform:translateY(-50%);font-size:14px;pointer-events:none}
.hdr-actions{display:flex;gap:6px;align-items:center;flex-shrink:0}
.loc-btn{display:flex;align-items:center;gap:3px;background:rgba(255,255,255,0.14);border:1px solid rgba(255,255,255,0.24);border-radius:16px;padding:5px 9px;cursor:pointer;color:#fff;font-size:11px;font-weight:600;font-family:'Poppins',sans-serif;max-width:85px}
.loc-btn span{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:60px}

/* CART ICON BUTTON */
.cart-icon-btn{position:relative;background:var(--or);border:none;border-radius:50%;width:38px;height:38px;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(244,124,32,.4);flex-shrink:0;transition:transform .15s}
.cart-icon-btn:active{transform:scale(.92)}
.cart-icon-btn svg{width:20px;height:20px;fill:none;stroke:#fff;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.cart-badge{position:absolute;top:-4px;right:-4px;background:#fff;color:var(--or);border-radius:50%;min-width:18px;height:18px;font-size:10px;font-weight:800;display:flex;align-items:center;justify-content:center;border:1.5px solid var(--or);padding:0 2px}

/* NAV CATS */
.nav-row{display:flex;overflow-x:auto;background:rgba(0,0,0,.18);scrollbar-width:none;padding:0 4px}
.nav-row::-webkit-scrollbar{display:none}
.nc{border:none;background:transparent;color:rgba(255,255,255,.75);padding:8px 13px;font-size:12px;font-family:'Poppins',sans-serif;font-weight:600;cursor:pointer;white-space:nowrap;border-bottom:2.5px solid transparent;transition:all .2s;flex-shrink:0}
.nc.act,.nc:hover{color:#fff;border-bottom-color:var(--gd);background:rgba(255,255,255,.08)}

/* HERO */
.hero{background:linear-gradient(135deg,#053d18,#0e6630,#1a8a3f);padding:16px 14px;text-align:center}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(19px,4vw,30px);color:#fff;font-weight:900;margin-bottom:4px}
.hero p{color:#9de3b4;font-size:12px;margin-bottom:10px}
.hero-chips{display:flex;gap:7px;justify-content:center;flex-wrap:wrap}
.hchip{background:rgba(255,255,255,.13);border:1px solid rgba(255,255,255,.22);border-radius:16px;padding:3px 10px;color:#fff;font-size:11px;font-weight:600}

/* LAYOUT */
.layout{display:flex;gap:16px;padding:12px 12px 20px;max-width:1200px;margin:0 auto}

/* SIDEBAR CART — desktop only */
.sidebar-cart{width:300px;flex-shrink:0;display:none}
@@media(min-width:700px){.sidebar-cart{display:block;position:sticky;top:72px;align-self:flex-start}}
.sc-box{background:var(--wh);border-radius:var(--r);border:1.5px solid var(--bd);overflow:hidden;box-shadow:var(--sh)}
.sc-hdr{background:linear-gradient(135deg,#063d1a,#1a7a3c);color:#fff;padding:12px 14px;display:flex;align-items:center;gap:8px}
.sc-hdr h3{font-size:14px;font-weight:700;flex:1}
.sc-body{padding:10px;max-height:420px;overflow-y:auto}
.sc-empty{text-align:center;padding:30px 10px;color:var(--tx2)}
.sc-empty div{font-size:38px;margin-bottom:8px}
.sc-empty p{font-size:12px;font-weight:600}
.sc-item{display:flex;align-items:center;gap:8px;padding:8px 0;border-bottom:1px solid #f0f0f0}
.sc-item img{width:40px;height:40px;border-radius:8px;object-fit:cover;border:1px solid var(--bd)}
.sc-item-info{flex:1;min-width:0}
.sc-item-name{font-size:11px;font-weight:700;color:var(--tx);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sc-item-wt{font-size:10px;color:var(--tx3)}
.sc-item-right{display:flex;flex-direction:column;align-items:flex-end;gap:4px}
.sc-item-price{font-size:12px;font-weight:800;color:var(--g2)}
.sc-qctrl{display:flex;align-items:center;gap:4px}
.sc-qbtn{width:22px;height:22px;border-radius:6px;border:1.5px solid var(--g2);background:#fff;color:var(--g2);font-size:14px;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;transition:all .15s}
.sc-qbtn:hover{background:var(--g2);color:#fff}
.sc-qnum{font-size:12px;font-weight:800;color:var(--g2);min-width:16px;text-align:center}
.sc-foot{padding:12px;border-top:2px solid var(--bd)}
.sc-total-row{display:flex;justify-content:space-between;font-size:12px;color:var(--tx2);margin-bottom:3px}
.sc-total-row.big{font-size:15px;font-weight:800;color:var(--tx);margin:8px 0 10px}
.sc-total-row.big span:last-child{color:var(--g2)}
.order-now-btn{width:100%;background:linear-gradient(135deg,var(--g2),var(--g3));color:#fff;border:none;border-radius:10px;padding:12px;font-size:14px;font-weight:700;font-family:'Poppins',sans-serif;cursor:pointer;transition:opacity .2s;letter-spacing:.3px}
.order-now-btn:hover{opacity:.9}

/* MAIN CONTENT */
.main-col{flex:1;min-width:0}
.stitle{font-size:15px;font-weight:700;color:var(--g1);margin:0 0 10px;display:flex;align-items:center;gap:7px}
.stitle::after{content:'';flex:1;height:1.5px;background:linear-gradient(90deg,var(--g4),transparent)}

/* CAT CHIPS */
.cat-row{display:flex;gap:10px;overflow-x:auto;padding:2px 0 10px;scrollbar-width:none;margin-bottom:4px}
.cat-row::-webkit-scrollbar{display:none}
.cc{display:flex;flex-direction:column;align-items:center;gap:4px;flex-shrink:0;cursor:pointer}
.cc-img{width:56px;height:56px;border-radius:16px;object-fit:cover;border:2.5px solid transparent;transition:all .2s;box-shadow:var(--sh)}
.cc.act .cc-img,.cc:hover .cc-img{border-color:var(--g2);box-shadow:0 4px 14px rgba(26,122,60,.22)}
.cc-lbl{font-size:10px;font-weight:700;color:var(--tx2)}
.cc.act .cc-lbl{color:var(--g2)}

/* PRODUCT GRID */
.pgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
@@media(min-width:500px){.pgrid{grid-template-columns:repeat(3,1fr)}}
@@media(min-width:900px){.pgrid{grid-template-columns:repeat(3,1fr)}}
@@media(min-width:1100px){.pgrid{grid-template-columns:repeat(4,1fr)}}

/* PRODUCT CARD */
.pcard{background:var(--wh);border-radius:var(--r);border:1.5px solid var(--bd);overflow:hidden;position:relative;transition:transform .2s,box-shadow .2s}
.pcard:hover{box-shadow:0 6px 20px rgba(26,122,60,.13);border-color:#b2dfbd;transform:translateY(-2px)}
.pbadge{position:absolute;top:7px;left:7px;background:var(--rd);color:#fff;font-size:9px;font-weight:800;padding:2px 7px;border-radius:5px;z-index:2}
.pbadge.fr{background:var(--g2)}
.pimg-wrap{position:relative;width:100%;padding-top:75%;overflow:hidden;background:#f0f8f2}
.pimg-wrap img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform .3s}
.pcard:hover .pimg-wrap img{transform:scale(1.06)}
.pinfo{padding:9px}
.pname{font-size:12px;font-weight:700;color:var(--tx);line-height:1.35;margin-bottom:2px;min-height:30px}
.pwt{font-size:10px;color:var(--tx3);margin-bottom:7px}
.pfoot{display:flex;align-items:center;justify-content:space-between;gap:4px}
.pprice-wrap{display:flex;flex-direction:column}
.pprice{font-size:14px;font-weight:800;color:var(--g2)}
.pmrp{font-size:10px;color:#bbb;text-decoration:line-through}

/* ADD / QTY CONTROL — Zepto style */
.add-btn{background:var(--wh);border:2px solid var(--g2);border-radius:8px;padding:5px 12px;font-size:12px;font-weight:700;color:var(--g2);cursor:pointer;font-family:'Poppins',sans-serif;transition:all .18s;white-space:nowrap}
.add-btn:hover{background:var(--g4)}
.add-btn:active{transform:scale(.95)}
.qctrl{display:flex;align-items:center;gap:0;border:2px solid var(--g2);border-radius:8px;overflow:hidden;background:var(--wh)}
.qbtn{width:28px;height:28px;border:none;background:transparent;color:var(--g2);font-size:16px;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;font-family:'Poppins',sans-serif;transition:background .15s}
.qbtn:hover{background:var(--g4)}
.qbtn:active{background:var(--g2);color:#fff}
.qnum{font-size:13px;font-weight:800;color:var(--g2);min-width:22px;text-align:center}

/* MOBILE BOTTOM BAR */
.mob-cart-bar{display:flex;position:fixed;bottom:0;left:0;right:0;z-index:180;background:var(--g2);color:#fff;align-items:center;padding:10px 14px;gap:10px;box-shadow:0 -2px 16px rgba(0,0,0,.18);cursor:pointer;transition:all .2s}
.mob-cart-bar:hover{background:var(--g1)}
@@media(min-width:700px){.mob-cart-bar{display:none}}
.mob-cart-icon{position:relative;width:38px;height:38px;background:rgba(255,255,255,.2);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.mob-cart-icon svg{width:20px;height:20px;fill:none;stroke:#fff;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.mob-cart-badge{position:absolute;top:-4px;right:-4px;background:#fff;color:var(--g2);border-radius:50%;min-width:18px;height:18px;font-size:10px;font-weight:800;display:flex;align-items:center;justify-content:center}
.mob-cart-info{flex:1}
.mob-cart-info .mc-count{font-size:12px;font-weight:600;opacity:.85}
.mob-cart-info .mc-total{font-size:15px;font-weight:800}
.mob-cart-info .mc-items{font-size:11px;opacity:.8;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.mob-view-btn{background:rgba(255,255,255,.22);border:1.5px solid rgba(255,255,255,.4);border-radius:20px;padding:6px 14px;font-size:12px;font-weight:700;color:#fff;font-family:'Poppins',sans-serif;white-space:nowrap;flex-shrink:0}

/* MOBILE CART DRAWER */
.cart-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:250;opacity:0;pointer-events:none;transition:opacity .25s}
.cart-overlay.open{opacity:1;pointer-events:all}
.cart-drawer{position:fixed;bottom:0;left:0;right:0;background:var(--wh);border-radius:20px 20px 0 0;z-index:260;transform:translateY(100%);transition:transform .32s cubic-bezier(.34,1.3,.64,1);max-height:85vh;display:flex;flex-direction:column}
.cart-drawer.open{transform:translateY(0)}
.cd-handle{width:36px;height:4px;background:var(--bd);border-radius:4px;margin:12px auto 0}
.cd-hdr{padding:12px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--bd)}
.cd-hdr h2{font-size:16px;font-weight:700;color:var(--tx)}
.cd-close{background:none;border:none;font-size:20px;cursor:pointer;color:var(--tx2);line-height:1}
.cd-body{flex:1;overflow-y:auto;padding:10px 14px}
.cd-empty{text-align:center;padding:40px 20px;color:var(--tx2)}
.cd-empty div{font-size:48px;margin-bottom:10px}
.cd-item{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid #f0f0f0}
.cd-item img{width:48px;height:48px;border-radius:10px;object-fit:cover;border:1px solid var(--bd);flex-shrink:0}
.cd-item-info{flex:1;min-width:0}
.cd-item-name{font-size:13px;font-weight:700;color:var(--tx);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cd-item-wt{font-size:11px;color:var(--tx3);margin-top:1px}
.cd-item-right{display:flex;flex-direction:column;align-items:flex-end;gap:5px;flex-shrink:0}
.cd-item-price{font-size:13px;font-weight:800;color:var(--g2)}
.cd-qctrl{display:flex;align-items:center;gap:0;border:2px solid var(--g2);border-radius:8px;overflow:hidden;background:var(--wh)}
.cd-qbtn{width:28px;height:26px;border:none;background:transparent;color:var(--g2);font-size:16px;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .15s}
.cd-qbtn:active{background:var(--g2);color:#fff}
.cd-qnum{font-size:13px;font-weight:800;color:var(--g2);min-width:24px;text-align:center}
.cd-foot{padding:14px 16px;border-top:2px solid var(--bd)}
.cd-total-row{display:flex;justify-content:space-between;font-size:12px;color:var(--tx2);margin-bottom:3px}
.cd-total-row.big{font-size:16px;font-weight:800;color:var(--tx);margin:8px 0 12px}
.cd-total-row.big span:last-child{color:var(--g2)}
.cd-order-btn{width:100%;background:linear-gradient(135deg,var(--g2),var(--g3));color:#fff;border:none;border-radius:12px;padding:14px;font-size:15px;font-weight:700;font-family:'Poppins',sans-serif;cursor:pointer;letter-spacing:.3px}

/* ORDER FORM MODAL */
.form-overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:300;display:flex;align-items:center;justify-content:center;padding:16px;opacity:0;pointer-events:none;transition:opacity .25s}
.form-overlay.open{opacity:1;pointer-events:all}
.form-box{background:var(--wh);border-radius:18px;width:100%;max-width:440px;max-height:90vh;overflow-y:auto;transform:scale(.9);transition:transform .3s cubic-bezier(.34,1.4,.64,1)}
.form-overlay.open .form-box{transform:scale(1)}
.form-hdr{background:linear-gradient(135deg,#063d1a,#1a7a3c);color:#fff;padding:16px 18px;border-radius:18px 18px 0 0;display:flex;align-items:center;justify-content:space-between}
.form-hdr h2{font-size:16px;font-weight:700}
.form-close{background:rgba(255,255,255,.2);border:none;color:#fff;border-radius:50%;width:28px;height:28px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center}
.form-body{padding:18px}
.form-label{font-size:12px;font-weight:700;color:var(--tx2);margin-bottom:5px;display:block;margin-top:13px}
.form-label:first-child{margin-top:0}
.form-input{width:100%;padding:11px 13px;border:2px solid var(--bd);border-radius:10px;font-size:14px;font-family:'Poppins',sans-serif;color:var(--tx);outline:none;transition:border .2s;background:var(--wh)}
.form-input:focus{border-color:var(--g2)}
.form-input::placeholder{color:var(--tx3);font-size:13px}
/* Order summary in form */
.form-summary{background:#f8fdf9;border:1.5px solid #c8e6c9;border-radius:10px;padding:12px;margin:14px 0}
.form-summary h4{font-size:12px;font-weight:700;color:var(--g1);margin-bottom:8px}
.fs-item{display:flex;justify-content:space-between;font-size:12px;color:var(--tx2);padding:3px 0;border-bottom:1px solid #e8f5e9}
.fs-item:last-child{border:none}
.fs-item span:last-child{font-weight:700;color:var(--tx)}
.fs-total{display:flex;justify-content:space-between;font-size:14px;font-weight:800;color:var(--g2);margin-top:8px;padding-top:8px;border-top:2px solid #c8e6c9}
.wa-confirm-btn{width:100%;background:#25D366;color:#fff;border:none;border-radius:12px;padding:14px;font-size:15px;font-weight:700;font-family:'Poppins',sans-serif;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;margin-top:16px;box-shadow:0 4px 14px rgba(37,211,102,.3);transition:opacity .2s}
.wa-confirm-btn:hover{opacity:.9}

/* WA FAB */
.wafab{position:fixed;right:14px;z-index:190;background:#25D366;color:#fff;border:none;border-radius:50%;width:50px;height:50px;cursor:pointer;box-shadow:0 4px 18px rgba(37,211,102,.5);display:flex;align-items:center;justify-content:center;animation:wap 2.5s infinite;bottom:80px}
@@media(min-width:700px){.wafab{bottom:20px}}
@@keyframes wap{0%,100%{box-shadow:0 4px 16px rgba(37,211,102,.45)}50%{box-shadow:0 4px 28px rgba(37,211,102,.7),0 0 0 7px rgba(37,211,102,.1)}}

/* LOC MODAL */
.loc-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:310;display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .25s}
.loc-overlay.open{opacity:1;pointer-events:all}
.loc-box{background:var(--wh);border-radius:20px 20px 0 0;padding:18px 16px 28px;width:100%;max-width:480px;max-height:80vh;overflow-y:auto;transform:translateY(100%);transition:transform .3s cubic-bezier(.34,1.3,.64,1)}
.loc-overlay.open .loc-box{transform:translateY(0)}
.loc-handle{width:36px;height:4px;background:var(--bd);border-radius:4px;margin:0 auto 14px;cursor:pointer}
.loc-box h3{font-size:16px;font-weight:700;color:var(--g1);margin-bottom:3px}
.dsel{width:100%;padding:10px 12px;border:2px solid var(--bd);border-radius:10px;font-size:14px;font-family:'Poppins',sans-serif;font-weight:600;color:var(--tx);outline:none;cursor:pointer;margin:10px 0;background:var(--wh)}
.dsel:focus{border-color:var(--g2)}
.lloc{display:grid;grid-template-columns:1fr 1fr;gap:7px;max-height:180px;overflow-y:auto}
.litem{border:2px solid var(--bd);border-radius:9px;padding:8px 10px;cursor:pointer;transition:all .15s;font-size:12px;font-weight:700;color:var(--tx2)}
.litem:hover,.litem.sel{border-color:var(--g2);background:var(--g4);color:var(--g2)}
.lbtn{width:100%;background:var(--g2);color:#fff;border:none;border-radius:10px;padding:12px;font-size:14px;font-weight:700;font-family:'Poppins',sans-serif;cursor:pointer;margin-top:12px}

/* TOAST */
.toast{position:fixed;bottom:85px;left:50%;transform:translateX(-50%) translateY(14px);background:#111;color:#fff;padding:9px 18px;border-radius:20px;font-weight:600;font-size:12px;z-index:400;transition:all .28s;opacity:0;pointer-events:none;white-space:nowrap;display:flex;align-items:center;gap:6px}
.toast.show{transform:translateX(-50%) translateY(0);opacity:1}
@@media(min-width:700px){.toast{bottom:24px}}

.foot{background:#063d1a;color:#9de3b4;text-align:center;padding:14px;font-size:11px;margin-top:12px}
.foot strong{color:#fff;display:block;font-size:13px;margin-bottom:2px}
</style>

<h2 class="sr-only">Grand Fresh Supermarket - Order Form and WhatsApp</h2>

<!-- HEADER -->
<div class="hdr">
  <div class="hdr-top">
    <div class="logo" onclick="openLoc()">
      <div class="logo-ring"><img src="https://images.unsplash.com/photo-1542838132-92c53300491e?w=80&h=80&fit=crop&crop=center" alt="logo"/></div>
      <div class="logo-txt"><b>Grand Fresh</b><span>Supermarket</span></div>
    </div>
    <div class="search-wrap">
      <input type="text" id="si" placeholder="Search vegetables, fruits..."/>
      <span class="search-icon">🔍</span>
    </div>
    <div class="hdr-actions">
      <button class="loc-btn" onclick="openLoc()">📍<span id="locTxt">Location</span></button>
      <!-- Desktop cart icon -->
      <button class="cart-icon-btn" onclick="openCartDrawer()" style="display:none" id="deskCartBtn">
        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span class="cart-badge" id="deskCartBadge">0</span>
      </button>
    </div>
  </div>
  <div class="nav-row">
