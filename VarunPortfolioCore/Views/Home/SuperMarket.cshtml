  {id:43,n:'Ariel Detergent',w:'1 kg',p:185,m:220,img:'https://images.unsplash.com/photo-1563453392212-326f5e854473?w=300&h=225&fit=crop',c:'household',b:'16% OFF'},
  {id:44,n:'Vim Dishwash',w:'200 g',p:20,m:25,img:'https://images.unsplash.com/photo-1585670891407-47b5b30d3219?w=300&h=225&fit=crop',c:'household',b:null},
];

let cart={}, activeCat='all', selLoc='Chennai', selDist='Chennai';
document.getElementById('locTxt').textContent='Chennai';
document.getElementById('fCity').value='Chennai';

// Responsive: show correct UI
function checkBreakpoint(){
  const isDesk=window.innerWidth>=700;
  document.getElementById('mobCartBar').style.display=Object.keys(cart).length>0&&!isDesk?'flex':'none';
  document.getElementById('deskCartBtn').style.display=isDesk?'flex':'none';
}
window.addEventListener('resize',checkBreakpoint);

function render(list){
  const g=document.getElementById('pgrid');
  const nr=document.getElementById('noRes');
  if(!list.length){g.innerHTML='';nr.style.display='block';return;}
  nr.style.display='none';
  g.innerHTML=list.map(p=>{
    const q=cart[p.id]?.q||0;
    const disc=p.m>p.p?Math.round((1-p.p/p.m)*100):0;
    const bdg=p.b||(disc>0?disc+'% OFF':null);
    return `<div class="pcard">
      ${bdg?`<div class="pbadge ${p.bc||''}">${bdg}</div>`:''}
      <div class="pimg-wrap"><img src="${p.img}" alt="${p.n}" loading="lazy"/></div>
      <div class="pinfo">
        <div class="pname">${p.n}</div>
        <div class="pwt">${p.w}</div>
        <div class="pfoot">
          <div class="pprice-wrap"><div class="pprice">₹${p.p}</div><div class="pmrp">₹${p.m}</div></div>
          ${q===0
            ?`<button class="add-btn" onclick="addC(${p.id})">+ Add</button>`
            :`<div class="qctrl">
               <button class="qbtn" onclick="chgQ(${p.id},-1)">−</button>
               <span class="qnum">${q}</span>
               <button class="qbtn" onclick="chgQ(${p.id},1)">+</button>
             </div>`}
        </div>
      </div>
    </div>`;
  }).join('');
}

function getList(){
  const q=document.getElementById('si').value.toLowerCase().trim();
  return prods.filter(p=>(activeCat==='all'||p.c===activeCat)&&(!q||p.n.toLowerCase().includes(q)));
}
document.getElementById('si').addEventListener('input',()=>render(getList()));

function fcat(cat,nb,cb){
  activeCat=cat;
  document.querySelectorAll('.nc').forEach(x=>x.classList.remove('act'));
  document.querySelectorAll('.cc').forEach(x=>x.classList.remove('act'));
  if(nb)nb.classList.add('act');
  if(cb)cb.classList.add('act');
  render(getList());
}

function addC(id){
  const p=prods.find(x=>x.id===id);
  if(!cart[id])cart[id]={...p,q:0};
  cart[id].q++;
  updAll();
  toast('✅ '+p.n+' added!');
  render(getList());
}
function chgQ(id,d){
  if(!cart[id])return;
  cart[id].q+=d;
  if(cart[id].q<=0)delete cart[id];
  updAll();
  render(getList());
}

function updAll(){
  const items=Object.values(cart);
  const total=items.reduce((s,i)=>s+i.p*i.q,0);
  const count=items.reduce((s,i)=>s+i.q,0);
  const isDesk=window.innerWidth>=700;

  // Desktop sidebar
  document.getElementById('scCount').textContent=count+' items';
  document.getElementById('deskCartBadge').textContent=count;
  const sb=document.getElementById('scBody'),sf=document.getElementById('scFoot');
  if(!items.length){
    sb.innerHTML='<div class="sc-empty"><div>🛒</div><p>Cart is empty!<br>Add fresh items</p></div>';
    sf.style.display='none';
  } else {
    sf.style.display='block';
    sb.innerHTML=items.map(i=>`
      <div class="sc-item">
        <img src="${i.img}" alt="${i.n}" onerror="this.style.display='none'"/>
        <div class="sc-item-info"><div class="sc-item-name">${i.n}</div><div class="sc-item-wt">${i.w}</div></div>
        <div class="sc-item-right">
          <div class="sc-item-price">₹${i.p*i.q}</div>
          <div class="sc-qctrl">
            <button class="sc-qbtn" onclick="chgQ(${i.id},-1)">−</button>
            <span class="sc-qnum">${i.q}</span>
            <button class="sc-qbtn" onclick="chgQ(${i.id},1)">+</button>
          </div>
        </div>
      </div>`).join('');
    document.getElementById('scSub').textContent='₹'+total;
    document.getElementById('scTotal').textContent='₹'+total;
  }

  // Mobile bottom bar
  const mbb=document.getElementById('mobCartBar');
  if(!isDesk&&items.length>0){
    mbb.style.display='flex';
    document.getElementById('mobBadge').textContent=count;
    document.getElementById('mobCount').textContent=count+' item'+(count>1?'s':'')+' in cart';
    document.getElementById('mobTotal').textContent='Total: ₹'+total;
    document.getElementById('mobItems').textContent=items.map(i=>i.n+' ×'+i.q).join(', ');
  } else {
    mbb.style.display='none';
  }

  // Mobile cart drawer
  const cb=document.getElementById('cdBody'),cf=document.getElementById('cdFoot');
  if(!items.length){
    cb.innerHTML='<div class="cd-empty"><div>🛒</div><p style="font-weight:600;color:#666">Cart is empty!<br><small>Add some fresh items</small></p></div>';
    cf.style.display='none';
  } else {
    cf.style.display='block';
    cb.innerHTML=items.map(i=>`
      <div class="cd-item">
        <img src="${i.img}" alt="${i.n}"/>
        <div class="cd-item-info"><div class="cd-item-name">${i.n}</div><div class="cd-item-wt">${i.w} × ${i.q} pack</div></div>
        <div class="cd-item-right">
          <div class="cd-item-price">₹${i.p*i.q}</div>
          <div class="cd-qctrl">
            <button class="cd-qbtn" onclick="chgQ(${i.id},-1)">−</button>
            <span class="cd-qnum">${i.q}</span>
            <button class="cd-qbtn" onclick="chgQ(${i.id},1)">+</button>
          </div>
        </div>
      </div>`).join('');
    document.getElementById('cdSub').textContent='₹'+total;
    document.getElementById('cdTotal').textContent='₹'+total;
  }
}

function openCartDrawer(){
  document.getElementById('cartOverlay').classList.add('open');
  document.getElementById('cartDrawer').classList.add('open');
}
function closeCartDrawer(){
  document.getElementById('cartOverlay').classList.remove('open');
  document.getElementById('cartDrawer').classList.remove('open');
}

function openOrderForm(){
  const items=Object.values(cart);
  if(!items.length){toast('❌ Cart is empty! Add items first.');return;}
  const total=items.reduce((s,i)=>s+i.p*i.q,0);
  document.getElementById('fCity').value=selLoc||'Chennai';
  // Fill summary
  document.getElementById('formItems').innerHTML=items.map(i=>`
    <div class="fs-item">
      <span>${i.n} (${i.w}) × ${i.q}</span>
      <span>₹${i.p*i.q}</span>
    </div>`).join('');
  document.getElementById('formTotal').textContent='₹'+total;
  document.getElementById('formOverlay').classList.add('open');
}
function closeOrderForm(){document.getElementById('formOverlay').classList.remove('open');}

function sendWA(){
  const name=document.getElementById('fName').value.trim();
  const phone=document.getElementById('fPhone').value.trim();
  const addr=document.getElementById('fAddr').value.trim();
  const city=document.getElementById('fCity').value.trim();
  if(!name){alert('Please enter your name!');document.getElementById('fName').focus();return;}
  if(!phone||phone.length<10){alert('Please enter a valid phone number!');document.getElementById('fPhone').focus();return;}
  if(!addr){alert('Please enter your delivery address!');document.getElementById('fAddr').focus();return;}

  const items=Object.values(cart);
  const subtotal=items.reduce((s,i)=>s+i.p*i.q,0);
  const now=new Date();
  const date=now.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'});
  const time=now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});

  let msg='';
  msg+='🌿 *GRAND FRESH SUPERMARKET*\n';
  msg+='━━━━━━━━━━━━━━━━━━━━━━\n';
  msg+='📋 *ORDER DETAILS*\n';
  msg+='━━━━━━━━━━━━━━━━━━━━━━\n';
  msg+=`🗓 Date : ${date}   ⏰ ${time}\n`;
  msg+=`👤 Name : ${name}\n`;
  msg+=`📱 Phone : ${phone}\n`;
  msg+=`🏠 Address : ${addr}, ${city}\n`;
  msg+='━━━━━━━━━━━━━━━━━━━━━━\n';
  msg+='🛒 *ITEMS ORDERED*\n\n';
  items.forEach((i,idx)=>{
    msg+=`${idx+1}. *${i.n}*\n`;
    msg+=`   📦 Qty    : ${i.q} pack × ${i.w}\n`;
    msg+=`   💵 Rate   : ₹${i.p} per pack\n`;
    msg+=`   💰 Amount : *₹${i.p*i.q}*\n\n`;
  });
  msg+='━━━━━━━━━━━━━━━━━━━━━━\n';
  msg+=`🧾 Subtotal  :  ₹${subtotal}\n`;
  msg+=`🚚 Delivery  :  FREE ✅\n`;
  msg+='━━━━━━━━━━━━━━━━━━━━━━\n';
  msg+=`💳 *TOTAL AMOUNT :  ₹${subtotal}*\n`;
  msg+='━━━━━━━━━━━━━━━━━━━━━━\n\n';
  msg+='✅ Please confirm my order. 🙏\n';
  msg+='🌿 *Grand Fresh Supermarket*';

  window.open('https://wa.me/'+WA+'?text='+encodeURIComponent(msg),'_blank');
  closeOrderForm();
  toast('✅ Order sent to WhatsApp!');
}

function chatWA(){
  window.open('https://wa.me/'+WA+'?text='+encodeURIComponent('Hi Grand Fresh! 👋 I want to place an order.'),'_blank');
}

function openLoc(){document.getElementById('locMod').classList.add('open');}
function closeLoc(){document.getElementById('locMod').classList.remove('open');}
document.getElementById('locMod').addEventListener('click',function(e){if(e.target===this)closeLoc();});

