function loadLocs(){
  const d=document.getElementById('dsel').value;selDist=d;selLoc='';
  document.getElementById('locList').innerHTML=(locData[d]||[]).map(l=>`<div class="litem" onclick="pickLoc(this,'${l}')">${l}</div>`).join('');
}
function pickLoc(el,l){document.querySelectorAll('.litem').forEach(x=>x.classList.remove('sel'));el.classList.add('sel');selLoc=l;}
function setLoc(){
  if(!selDist){alert('Please select a district!');return;}
  const loc=selLoc||selDist;
  selLoc=loc;
  document.getElementById('locTxt').textContent=loc.length>9?loc.substring(0,9)+'..':loc;
  document.getElementById('fCity').value=loc;
  closeLoc();
  toast('📍 Location: '+loc);
}

function toast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),2400);
}

render(prods);
checkBreakpoint();
</script>
