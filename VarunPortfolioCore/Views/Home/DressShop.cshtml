    <script>
/* ── PRELOADER ── */
window.addEventListener('load',()=>{
  setTimeout(()=>{
    document.getElementById('preloader').classList.add('hide');
  },2000);
});

/* ── CURSOR ── */
const cur=document.getElementById('cur');
const curO=document.getElementById('cur-outer');
let mx=0,my=0,ox=0,oy=0;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  cur.style.left=mx+'px';cur.style.top=my+'px';
});
(function loop(){
  ox+=(mx-ox)*.13;oy+=(my-oy)*.13;
  curO.style.left=ox+'px';curO.style.top=oy+'px';
  requestAnimationFrame(loop);
})();
document.querySelectorAll('a,button,.cat-card,.prod-card,.arr-card,.review-card,.soc-btn').forEach(el=>{
  el.addEventListener('mouseenter',()=>{
    curO.style.width='56px';curO.style.height='56px';
    curO.style.borderColor='rgba(124,92,74,.6)';
  });
  el.addEventListener('mouseleave',()=>{
    curO.style.width='44px';curO.style.height='44px';
    curO.style.borderColor='rgba(124,92,74,.4)';
  });
});

/* ── NAV SCROLL ── */
window.addEventListener('scroll',()=>{
  document.getElementById('nav').classList.toggle('scrolled',scrollY>60);
},{passive:true});

/* ── MOBILE MENU ── */
function toggleMob(){
  document.getElementById('hamBtn').classList.toggle('open');
  document.getElementById('mobMenu').classList.toggle('open');
  document.body.style.overflow=document.getElementById('mobMenu').classList.contains('open')?'hidden':'';
}
function closeMob(){
  document.getElementById('hamBtn').classList.remove('open');
  document.getElementById('mobMenu').classList.remove('open');
  document.body.style.overflow='';
}

/* ── CART ── */
let cartCount=3;
function toggleCart(){
  document.getElementById('cartOverlay').classList.toggle('open');
  document.body.style.overflow=document.getElementById('cartOverlay').classList.contains('open')?'hidden':'';
}
function addToCart(){
  cartCount++;
  document.querySelector('.cart-badge').textContent=cartCount;
  /* flash badge */
  const badge=document.querySelector('.cart-badge');
  badge.style.transform='scale(1.6)';badge.style.background='var(--gold)';
  setTimeout(()=>{badge.style.transform='';badge.style.background='';},400);
}

/* ── REVEAL ── */
const rIO=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      setTimeout(()=>e.target.classList.add('on'),parseInt(e.target.dataset.delay||0));
      rIO.unobserve(e.target);
    }
  });
},{threshold:.1});
document.querySelectorAll('[data-r]').forEach(el=>rIO.observe(el));

/* ── COUNTER ── */
function countUp(el,end,suffix=''){
  let s=0;
  const r=ts=>{
    if(!s)s=ts;
    const p=Math.min((ts-s)/1600,1);
    el.textContent=Math.floor(p*end)+suffix;
    if(p<1)requestAnimationFrame(r);
  };
  requestAnimationFrame(r);
}
const cIO=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      document.querySelectorAll('.hs-num').forEach(el=>{
        const v=parseInt(el.dataset.count);
        const s=el.textContent.replace(/[0-9]/g,'');
        countUp(el,v,s);
      });
      cIO.disconnect();
    }
  });
},{threshold:.5});
const hs=document.querySelector('.h-stats');
if(hs)cIO.observe(hs);

/* ── NEWSLETTER ── */
function subscribeNL(btn){
  const inp=btn.previousElementSibling;
  if(!inp.value.includes('@@')){inp.style.borderColor='#c0392b';return;}
  btn.textContent='✓ Subscribed!';btn.style.background='var(--deep)';
  inp.value='';
  setTimeout(()=>{btn.textContent='Subscribe';btn.style.background='';},3000);
}
    </script>
