// COUNTER ANIMATION
function animCount(el, target, suffix){
  let cur=0;
  const step = target/60;
  const iv = setInterval(()=>{
    cur = Math.min(cur+step, target);
    el.textContent = Math.floor(cur) + suffix;
    if(cur>=target) clearInterval(iv);
  }, 25);
}
const statsObs = new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      document.querySelectorAll('.hs-n').forEach(el=>{
        const t = el.textContent;
        if(t.includes('12')) animCount(el,12,'+');
        else if(t.includes('4K')) { let c=0; const iv=setInterval(()=>{c=Math.min(c+80,4000);el.textContent=Math.floor(c/1000)+'K+';if(c>=4000)clearInterval(iv);},20);}
        else if(t.includes('20')) animCount(el,20,'+');
        else if(t.includes('98')) animCount(el,98,'%');
      });
      statsObs.disconnect();
    }
  });
},{threshold:0.5});
const hStats = document.querySelector('.h-stats');
if(hStats) statsObs.observe(hStats);</script>
