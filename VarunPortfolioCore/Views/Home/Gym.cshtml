@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IronForge Fitness — Chennai</title>
    <link href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <style>
:root {
  --red:#E00000; --red2:#FF2222; --red3:#8B0000;
  --gold:#C8973A; --gold2:#E8B84B;
  --black:#060606; --dark:#0C0C0C; --card:#111;
  --border:rgba(224,0,0,0.15);
  --white:#F0EDE8; --muted:#666;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  background:var(--black);
  color:var(--white);
  font-family:'Rajdhani',sans-serif;
  overflow-x:hidden;
}
::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-track{background:#000;}
::-webkit-scrollbar-thumb{background:var(--red);}

/* ══ CANVAS BG ══ */
#bg-canvas{
  position:fixed;top:0;left:0;width:100%;height:100%;
  z-index:0;pointer-events:none;
}

/* ══ CURSOR ══ */
#cur{
  position:fixed;width:12px;height:12px;
  background:var(--red);border-radius:50%;
  pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);
  box-shadow:0 0 16px var(--red),0 0 32px rgba(224,0,0,0.4);
  transition:transform 0.08s;
}
#cur2{
  position:fixed;width:36px;height:36px;
  border:1px solid rgba(224,0,0,0.5);border-radius:50%;
  pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);
  transition:left 0.12s ease,top 0.12s ease;
}

/* ══ NAV ══ */
nav{
  position:fixed;top:0;width:100%;z-index:500;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 72px;height:68px;
  background:rgba(6,6,6,0.92);
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(24px);
  transition:border-color 0.3s;
}
.logo{
  font-family:'Black Han Sans',sans-serif;
  font-size:1.6rem;letter-spacing:6px;
  color:var(--white);
}
.logo b{color:var(--red);}
.nav-links{display:flex;gap:36px;list-style:none;align-items:center;}
.nav-links a{
  font-family:'Rajdhani',sans-serif;
  font-size:0.85rem;font-weight:600;
  letter-spacing:3px;text-transform:uppercase;
  color:var(--muted);text-decoration:none;
  transition:color 0.2s;position:relative;padding-bottom:4px;
}
.nav-links a::after{
  content:'';position:absolute;bottom:0;left:0;
  width:0;height:1px;background:var(--red);
  transition:width 0.3s;
}
.nav-links a:hover{color:var(--white);}
.nav-links a:hover::after{width:100%;}
.nav-cta{
  background:var(--red)!important;color:#fff!important;
  padding:9px 24px!important;font-weight:700!important;
}
.nav-cta::after{display:none!important;}
.nav-cta:hover{background:var(--red2)!important;color:#fff!important;}

/* ══ HERO ══ */
#hero{
  min-height:100vh;
  display:flex;align-items:center;
  position:relative;overflow:hidden;
  padding:68px 72px 0;
  z-index:1;
}
.hero-vignette{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 60% 80% at 65% 50%,rgba(140,0,0,0.12) 0%,transparent 70%),
    radial-gradient(ellipse 100% 40% at 50% 100%,rgba(0,0,0,0.9) 0%,transparent 60%),
    radial-gradient(ellipse 80% 30% at 50% 0%,rgba(0,0,0,0.7) 0%,transparent 50%);
  pointer-events:none;z-index:1;
}
.hero-content{position:relative;z-index:2;max-width:720px;}

/* STAGGERED ENTRY */
.hero-content>*{
  opacity:0;transform:translateY(40px);
  animation:slideUp 0.8s cubic-bezier(.16,1,.3,1) forwards;
}
.hero-content>*:nth-child(1){animation-delay:0.3s;}
.hero-content>*:nth-child(2){animation-delay:0.5s;}
.hero-content>*:nth-child(3){animation-delay:0.7s;}
.hero-content>*:nth-child(4){animation-delay:0.9s;}

.h-tag{
  display:flex;align-items:center;gap:14px;
  font-family:'Share Tech Mono',monospace;
  font-size:0.72rem;letter-spacing:4px;text-transform:uppercase;
  color:var(--red);margin-bottom:26px;
}
.h-tag::before{
  content:'';width:50px;height:1px;
  background:linear-gradient(90deg,var(--red3),var(--red));
}
.h-tag::after{
  content:'_';animation:blink 1s step-end infinite;
}
@@keyframes blink{0%,100%{opacity:1;}50%{opacity:0;}}

h1{
  font-family:'Black Han Sans',sans-serif;
  font-size:clamp(4rem,9vw,9.5rem);
  line-height:0.88;letter-spacing:4px;
  margin-bottom:8px;
}
h1 .r{
  display:block;color:var(--red);
  text-shadow:0 0 80px rgba(224,0,0,0.6),0 0 160px rgba(224,0,0,0.2);
  animation:pulse-glow 3s ease-in-out infinite;
}
@@keyframes pulse-glow{
  0%,100%{text-shadow:0 0 80px rgba(224,0,0,0.6),0 0 160px rgba(224,0,0,0.2);}
  50%{text-shadow:0 0 120px rgba(224,0,0,0.9),0 0 240px rgba(224,0,0,0.35);}
}
.h-sub{
  font-size:1.05rem;font-weight:400;color:#888;
  line-height:1.8;max-width:500px;
  margin-bottom:44px;margin-top:20px;
  letter-spacing:0.5px;
}
.ctas{display:flex;gap:14px;flex-wrap:wrap;}
.btn-fire{
  display:inline-flex;align-items:center;gap:10px;
  background:var(--red);color:#fff;
  font-family:'Rajdhani',sans-serif;
  font-size:0.88rem;font-weight:700;
  letter-spacing:3px;text-transform:uppercase;
  padding:15px 36px;text-decoration:none;
  clip-path:polygon(0 0,calc(100% - 14px) 0,100% 14px,100% 100%,14px 100%,0 calc(100% - 14px));
  transition:background 0.2s,transform 0.2s,box-shadow 0.2s;
}
.btn-fire:hover{
  background:var(--red2);transform:translateY(-3px);
  box-shadow:0 16px 48px rgba(224,0,0,0.45);
}
.btn-line{
  display:inline-flex;align-items:center;gap:10px;
  background:transparent;color:var(--white);
  font-family:'Rajdhani',sans-serif;
  font-size:0.88rem;font-weight:600;
  letter-spacing:3px;text-transform:uppercase;
  padding:14px 32px;text-decoration:none;
  border:1px solid rgba(255,255,255,0.15);
  transition:border-color 0.2s,color 0.2s;
}
.btn-line:hover{border-color:var(--red);color:var(--red);}

/* HERO STATS */
.h-stats{
  position:absolute;right:72px;top:50%;transform:translateY(-50%);
  z-index:2;display:flex;flex-direction:column;align-items:center;gap:0;
  opacity:0;animation:slideUp 0.8s cubic-bezier(.16,1,.3,1) 1s forwards;
}
.hs{text-align:center;padding:22px 28px;}
.hs-n{
  font-family:'Black Han Sans',sans-serif;
  font-size:3rem;color:var(--red);line-height:1;
  text-shadow:0 0 30px rgba(224,0,0,0.5);
}
.hs-l{
  font-family:'Share Tech Mono',monospace;
  font-size:0.6rem;letter-spacing:3px;
  text-transform:uppercase;color:var(--muted);margin-top:4px;
}
.hs-sep{width:1px;height:28px;background:var(--border);}

/* ══ SCROLL REVEAL ══ */
.reveal{
  opacity:0;transform:translateY(50px);
  transition:opacity 0.7s ease,transform 0.7s ease;
}
.reveal.visible{opacity:1;transform:translateY(0);}
.reveal-l{opacity:0;transform:translateX(-50px);transition:opacity 0.7s ease,transform 0.7s ease;}
.reveal-l.visible{opacity:1;transform:translateX(0);}
.reveal-r{opacity:0;transform:translateX(50px);transition:opacity 0.7s ease,transform 0.7s ease;}
.reveal-r.visible{opacity:1;transform:translateX(0);}

/* ══ SECTIONS ══ */
section{padding:110px 72px;position:relative;z-index:1;}
.eyebrow{
  display:flex;align-items:center;gap:12px;
  font-family:'Share Tech Mono',monospace;
  font-size:0.68rem;letter-spacing:5px;text-transform:uppercase;
  color:var(--red);margin-bottom:14px;
}
.eyebrow::before{content:'';width:30px;height:1px;background:var(--red);}
h2{
  font-family:'Black Han Sans',sans-serif;
  font-size:clamp(2.8rem,5.5vw,5.2rem);
  line-height:0.9;letter-spacing:3px;margin-bottom:16px;
}
h2 span{color:var(--red);}

/* ══ PROGRAMS ══ */
#programs{background:rgba(10,10,10,0.85);}
.prog-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:2px;margin-top:56px;
}
.pc{
  background:rgba(14,14,14,0.9);
  padding:44px 30px;
  position:relative;overflow:hidden;
  border-left:3px solid transparent;
  transition:background 0.3s,border-color 0.3s,transform 0.3s;
  cursor:pointer;
}
.pc:hover{
  background:rgba(20,20,20,0.95);
  border-left-color:var(--red);
  transform:translateY(-4px);
}
.pc-n{
  font-family:'Black Han Sans',sans-serif;
  font-size:3.5rem;
  color:rgba(224,0,0,0.06);
  line-height:1;margin-bottom:14px;
  transition:color 0.3s;
}
.pc:hover .pc-n{color:rgba(224,0,0,0.18);}
.pc-ico{font-size:2rem;margin-bottom:12px;display:block;}
.pc h3{
  font-family:'Rajdhani',sans-serif;
  font-size:1.3rem;font-weight:700;
  letter-spacing:2px;text-transform:uppercase;
  margin-bottom:10px;
}
.pc p{color:#666;font-size:0.88rem;line-height:1.7;font-weight:400;}
.pc-arr{
  position:absolute;bottom:24px;right:24px;
  width:34px;height:34px;
  border:1px solid rgba(255,255,255,0.08);
  display:flex;align-items:center;justify-content:center;
  color:var(--muted);font-size:0.8rem;
  transition:all 0.3s;
  font-family:'Share Tech Mono',monospace;
}
.pc:hover .pc-arr{border-color:var(--red);color:var(--red);}

/* ══ MEMBERSHIP ══ */
#membership{background:rgba(6,6,6,0.88);}
.plans{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:2px;margin-top:56px;
}
.plan{
  background:rgba(14,14,14,0.9);
  padding:46px 34px;position:relative;
  border-top:3px solid transparent;
  transition:transform 0.3s,box-shadow 0.3s;
}
.plan:hover{transform:translateY(-8px);}
.plan.top{
  background:linear-gradient(160deg,rgba(25,0,0,0.95) 0%,rgba(16,0,0,0.95) 100%);
  border-top-color:var(--red);
  box-shadow:0 0 80px rgba(224,0,0,0.12);
}
.p-tier{
  font-family:'Share Tech Mono',monospace;
  font-size:0.65rem;letter-spacing:5px;
  text-transform:uppercase;color:var(--muted);margin-bottom:22px;
}
.plan.top .p-tier{color:rgba(224,0,0,0.7);}
.p-amt{
  font-family:'Black Han Sans',sans-serif;
  font-size:4.2rem;line-height:1;
  display:flex;align-items:flex-start;gap:4px;
}
.p-amt sup{
  font-size:1.3rem;margin-top:10px;
  font-family:'Rajdhani',sans-serif;font-weight:500;
}
.plan.top .p-amt{color:var(--red);text-shadow:0 0 30px rgba(224,0,0,0.4);}
.p-cycle{font-size:0.8rem;color:var(--muted);margin:6px 0 28px;}
.p-feats{list-style:none;margin-bottom:32px;}
.p-feats li{
  padding:10px 0;
  border-bottom:1px solid rgba(255,255,255,0.04);
  font-size:0.88rem;font-weight:500;color:#bbb;
  display:flex;align-items:center;gap:10px;
  letter-spacing:0.5px;
}
.p-feats li::before{content:'//';color:var(--red);font-family:'Share Tech Mono',monospace;font-size:0.65rem;flex-shrink:0;}
.p-feats li.no{opacity:0.28;text-decoration:line-through;}
.p-feats li.no::before{content:'//';color:#333;}
.btn-p{
  display:block;width:100%;padding:13px;
  text-align:center;
  font-family:'Rajdhani',sans-serif;
  font-size:0.85rem;font-weight:700;
  letter-spacing:3px;text-transform:uppercase;
  text-decoration:none;cursor:pointer;border:none;
  background:transparent;color:var(--white);
  border:1px solid rgba(255,255,255,0.12);
  transition:all 0.2s;
}
.btn-p:hover{border-color:var(--red);color:var(--red);}
.plan.top .btn-p{background:var(--red);border-color:var(--red);color:#fff;}
.plan.top .btn-p:hover{background:var(--red2);}
.badge{
  position:absolute;top:-1px;right:24px;
  background:var(--red);color:#fff;
  font-family:'Share Tech Mono',monospace;
  font-size:0.6rem;letter-spacing:2px;text-transform:uppercase;
  padding:5px 12px;
}

/* ══ TRAINERS ══ */
#trainers{background:rgba(10,10,10,0.85);}
.t-grid{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:16px;margin-top:56px;
}
.tc{
  background:rgba(14,14,14,0.9);
  overflow:hidden;position:relative;
  transition:transform 0.3s;cursor:pointer;
}
.tc:hover{transform:translateY(-6px);}
.tc-vis{
  width:100%;aspect-ratio:3/4;
  display:flex;align-items:center;justify-content:center;
  font-size:5rem;position:relative;overflow:hidden;
}
.tc-bg{
  position:absolute;inset:0;
  background:linear-gradient(135deg,#1a0000,#1c1414);
  transition:transform 0.5s;
}
.tc:hover .tc-bg{transform:scale(1.05);}
.tc-overlay{
  position:absolute;inset:0;
  background:linear-gradient(0deg,rgba(224,0,0,0.75) 0%,transparent 55%);
  opacity:0;transition:opacity 0.3s;
}
.tc:hover .tc-overlay{opacity:1;}
.tc-em{position:relative;z-index:1;}
/* TRAINER NAME overlay on hover */
.tc-hover-name{
  position:absolute;bottom:0;left:0;right:0;
  padding:16px;z-index:2;
  opacity:0;transform:translateY(8px);
  transition:opacity 0.3s,transform 0.3s;
}
.tc:hover .tc-hover-name{opacity:1;transform:translateY(0);}
.tc-hover-name span{
  font-family:'Share Tech Mono',monospace;
  font-size:0.7rem;letter-spacing:2px;
  text-transform:uppercase;color:#fff;
}
.tc-body{padding:18px 20px;}
.tc-name{
  font-family:'Black Han Sans',sans-serif;
  font-size:1.2rem;letter-spacing:2px;margin-bottom:3px;
}
.tc-role{
  font-family:'Share Tech Mono',monospace;
  font-size:0.62rem;letter-spacing:2px;
  text-transform:uppercase;color:var(--red);margin-bottom:8px;
}
.tc-body p{color:#666;font-size:0.82rem;line-height:1.6;}

/* ══ SCHEDULE ══ */
#schedule{background:rgba(6,6,6,0.88);}
.day-bar{
  display:flex;gap:0;margin-top:48px;
  border-bottom:1px solid rgba(255,255,255,0.05);
  overflow-x:auto;
}
.dt{
  padding:12px 24px;
  font-family:'Rajdhani',sans-serif;
  font-size:0.82rem;font-weight:700;
  letter-spacing:3px;text-transform:uppercase;
  cursor:pointer;border:none;background:transparent;
  color:var(--muted);border-bottom:2px solid transparent;
  margin-bottom:-1px;white-space:nowrap;
  transition:color 0.2s,border-color 0.2s;
}
.dt.on{color:var(--red);border-bottom-color:var(--red);}
.dt:hover:not(.on){color:var(--white);}
.s-table{width:100%;border-collapse:collapse;}
.s-table th{
  background:rgba(14,14,14,0.9);
  padding:12px 16px;
  font-family:'Share Tech Mono',monospace;
  font-size:0.6rem;font-weight:600;
  letter-spacing:3px;text-transform:uppercase;
  color:#444;text-align:left;
}
.s-table td{
  padding:14px 16px;
  border-bottom:1px solid rgba(255,255,255,0.03);
  font-size:0.88rem;
}
.s-table tr{transition:background 0.2s;}
.s-table tr:hover td{background:rgba(224,0,0,0.04);}
.cn{
  font-family:'Rajdhani',sans-serif;
  font-weight:700;font-size:0.95rem;
  letter-spacing:1px;
}
.cb{color:#555;font-size:0.72rem;margin-top:2px;font-family:'Share Tech Mono',monospace;}
.lv{
  display:inline-block;padding:3px 10px;
  font-family:'Share Tech Mono',monospace;
  font-size:0.6rem;letter-spacing:1px;text-transform:uppercase;
}
.lv.h{background:rgba(224,0,0,0.14);color:#ff4444;}
.lv.m{background:rgba(255,165,0,0.12);color:#ffaa33;}
.lv.l{background:rgba(0,200,100,0.1);color:#44cc88;}

/* ══ GALLERY ══ */
#gallery{background:rgba(10,10,10,0.85);}
.g-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  grid-template-rows:220px 220px;
  gap:4px;margin-top:56px;
}
.gc{
  display:flex;align-items:center;justify-content:center;
  font-size:3.5rem;position:relative;overflow:hidden;cursor:pointer;
}
.gc:nth-child(1){grid-column:span 2;grid-row:span 2;font-size:6rem;}
.gc-bg{
  position:absolute;inset:0;
  transition:transform 0.5s cubic-bezier(.16,1,.3,1);
}
.gc:hover .gc-bg{transform:scale(1.08);}
.gc-red{
  position:absolute;inset:0;
  background:rgba(224,0,0,0.55);
  opacity:0;transition:opacity 0.3s;
}
.gc:hover .gc-red{opacity:1;}
.gc-em{position:relative;z-index:1;transition:transform 0.3s;}
.gc:hover .gc-em{transform:scale(1.1);}
.gc-cap{
  position:absolute;bottom:0;left:0;right:0;
  padding:16px;z-index:2;
  background:linear-gradient(0deg,rgba(0,0,0,0.9) 0%,transparent 100%);
  font-family:'Rajdhani',sans-serif;
  font-size:0.85rem;font-weight:700;
  letter-spacing:3px;text-transform:uppercase;
  opacity:0;transform:translateY(6px);
  transition:opacity 0.3s,transform 0.3s;
}
.gc:hover .gc-cap{opacity:1;transform:translateY(0);}

/* ══ CONTACT ══ */
#contact{background:rgba(6,6,6,0.88);}
.c-wrap{
  display:grid;grid-template-columns:1fr 1.2fr;
  gap:80px;margin-top:56px;
}
.c-left h3{
  font-family:'Black Han Sans',sans-serif;
  font-size:1.8rem;letter-spacing:3px;margin-bottom:32px;
}
.ci{display:flex;gap:16px;align-items:flex-start;margin-bottom:26px;}
.ci-ico{
  width:44px;height:44px;flex-shrink:0;
  background:rgba(224,0,0,0.07);
  border:1px solid rgba(224,0,0,0.18);
  display:flex;align-items:center;justify-content:center;font-size:0.95rem;
}
.ci h4{
  font-family:'Share Tech Mono',monospace;
  font-size:0.6rem;letter-spacing:4px;text-transform:uppercase;
  color:var(--red);margin-bottom:5px;
}
.ci p{color:#777;font-size:0.88rem;line-height:1.6;}
.f-form{display:flex;flex-direction:column;gap:14px;}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.fg{display:flex;flex-direction:column;gap:7px;}
.fg label{
  font-family:'Share Tech Mono',monospace;
  font-size:0.58rem;letter-spacing:4px;text-transform:uppercase;color:#444;
}
.fg input,.fg select,.fg textarea{
  background:rgba(14,14,14,0.9);
  border:1px solid rgba(255,255,255,0.06);
  color:var(--white);
  padding:13px 15px;
  font-family:'Rajdhani',sans-serif;font-size:0.9rem;font-weight:500;
  outline:none;transition:border-color 0.2s,box-shadow 0.2s;resize:none;
}
.fg input:focus,.fg select:focus,.fg textarea:focus{
  border-color:var(--red);
  box-shadow:0 0 0 3px rgba(224,0,0,0.08);
}
.fg select option{background:#111;}

/* ══ FOOTER ══ */
footer{
  background:rgba(4,4,4,0.97);
  border-top:1px solid rgba(224,0,0,0.1);
  padding:60px 72px 26px;position:relative;z-index:1;
}
.ft{
  display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;
  gap:40px;margin-bottom:48px;
}
.fb .logo3{
  font-family:'Black Han Sans',sans-serif;
  font-size:1.8rem;letter-spacing:5px;color:var(--white);margin-bottom:14px;
}
.fb .logo3 b{color:var(--red);}
.fb p{color:#444;font-size:0.85rem;line-height:1.7;max-width:260px;}
.fc h5{
  font-family:'Share Tech Mono',monospace;
  font-size:0.6rem;letter-spacing:4px;text-transform:uppercase;
  color:#3a3a3a;margin-bottom:18px;
}
.fc ul{list-style:none;}
.fc li{margin-bottom:9px;}
.fc a{color:#555;text-decoration:none;font-size:0.88rem;transition:color 0.2s;font-weight:500;}
.fc a:hover{color:var(--red);}
.fb2{
  border-top:1px solid rgba(255,255,255,0.04);
  padding-top:20px;
  display:flex;justify-content:space-between;align-items:center;
  flex-wrap:wrap;gap:12px;
}
.fb2 p{color:#2e2e2e;font-size:0.75rem;font-family:'Share Tech Mono',monospace;}
