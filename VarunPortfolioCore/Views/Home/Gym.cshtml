    <!-- ══ THREE.JS ══ -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script>// ════════════════════════════════════
//  THREE.JS 3D GYM BACKGROUND
// ════════════════════════════════════
(function(){
  const canvas = document.getElementById('bg-canvas');
  const renderer = new THREE.WebGLRenderer({canvas, alpha:true, antialias:true});
  renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
  renderer.setSize(window.innerWidth, window.innerHeight);

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(60, window.innerWidth/window.innerHeight, 0.1, 1000);
  camera.position.set(0, 0, 18);

  // ── FLOATING 3D DUMBBELLS ──
  const dumbellGroup = new THREE.Group();
  scene.add(dumbellGroup);

  function makeDumbbell() {
    const g = new THREE.Group();
    // Bar
    const bar = new THREE.Mesh(
      new THREE.CylinderGeometry(0.08, 0.08, 2.2, 8),
      new THREE.MeshStandardMaterial({color:0x333333, metalness:0.9, roughness:0.2})
    );
    bar.rotation.z = Math.PI/2;
    g.add(bar);
    // Plates (left/right)
    [-1.1, 1.1].forEach(x => {
      [0.3, 0.55].forEach((ox,i) => {
        const plate = new THREE.Mesh(
          new THREE.CylinderGeometry(0.36 - i*0.06, 0.36 - i*0.06, 0.18, 12),
          new THREE.MeshStandardMaterial({color:0x880000, metalness:0.8, roughness:0.3})
        );
        plate.rotation.z = Math.PI/2;
        plate.position.x = x + (i===0 ? (x>0?0.3:-0.3) : (x>0?0.55:-0.55));
        g.add(plate);
      });
    });
    return g;
  }

  // ── FLOATING BARBELLS (horizontal bars) ──
  function makeBarbell() {
    const g = new THREE.Group();
    const bar = new THREE.Mesh(
      new THREE.CylinderGeometry(0.05, 0.05, 4.5, 8),
      new THREE.MeshStandardMaterial({color:0x222222, metalness:0.95, roughness:0.1})
    );
    bar.rotation.z = Math.PI/2;
    g.add(bar);
    [-2.0, -1.6, 1.6, 2.0].forEach(x => {
      const plate = new THREE.Mesh(
        new THREE.CylinderGeometry(0.5, 0.5, 0.22, 14),
        new THREE.MeshStandardMaterial({color:0xAA0000, metalness:0.7, roughness:0.4})
      );
      plate.rotation.z = Math.PI/2;
      plate.position.x = x;
      g.add(plate);
    });
    return g;
  }

  // ── WEIGHT PLATES (circles) ──
  function makePlate(r, col) {
    const g = new THREE.Group();
    const ring = new THREE.Mesh(
      new THREE.TorusGeometry(r, 0.12, 8, 24),
      new THREE.MeshStandardMaterial({color:col, metalness:0.8, roughness:0.3})
    );
    g.add(ring);
    const inner = new THREE.Mesh(
      new THREE.CircleGeometry(r-0.1, 24),
      new THREE.MeshStandardMaterial({color:0x0a0a0a, metalness:0.1, roughness:0.9, transparent:true, opacity:0.7})
    );
    inner.position.z = 0.01;
    g.add(inner);
    return g;
  }

  // ── HEXAGONAL BUMPER PLATES ──
  function makeHexPlate(col) {
    const shape = new THREE.Shape();
    for(let i=0;i<6;i++){
      const angle = (i*Math.PI)/3 - Math.PI/6;
      const r = 0.7;
      i===0 ? shape.moveTo(Math.cos(angle)*r, Math.sin(angle)*r)
             : shape.lineTo(Math.cos(angle)*r, Math.sin(angle)*r);
    }
    shape.closePath();
    const geo = new THREE.ShapeGeometry(shape);
    const mat = new THREE.MeshStandardMaterial({color:col,metalness:0.6,roughness:0.4,side:THREE.DoubleSide});
    return new THREE.Mesh(geo, mat);
  }

  // ── KETTLE BELL ──
  function makeKettle() {
    const g = new THREE.Group();
    const ball = new THREE.Mesh(
      new THREE.SphereGeometry(0.45, 12, 10),
      new THREE.MeshStandardMaterial({color:0x1a1a1a, metalness:0.9, roughness:0.2})
    );
    g.add(ball);
    const handle = new THREE.Mesh(
      new THREE.TorusGeometry(0.28, 0.06, 8, 16, Math.PI),
      new THREE.MeshStandardMaterial({color:0x111111, metalness:0.95, roughness:0.1})
    );
    handle.position.y = 0.45;
    handle.rotation.x = Math.PI;
    g.add(handle);
    return g;
  }

  // POPULATE SCENE
  const objects = [];
  const spread = 22;

  // Dumbbells
  for(let i=0;i<8;i++){
    const d = makeDumbbell();
    d.position.set(
      (Math.random()-0.5)*spread,
      (Math.random()-0.5)*spread*0.7,
      (Math.random()-0.5)*12 - 4
    );
    d.rotation.set(Math.random()*Math.PI*2, Math.random()*Math.PI*2, Math.random()*Math.PI*2);
    d.scale.setScalar(0.7+Math.random()*0.6);
    dumbellGroup.add(d);
    objects.push({mesh:d, rx:0.002+Math.random()*0.004, ry:0.003+Math.random()*0.004, rz:0.001+Math.random()*0.003, fy:Math.random()*Math.PI*2, fspd:0.003+Math.random()*0.006, amp:0.04+Math.random()*0.08});
  }

  // Barbells
  for(let i=0;i<4;i++){
    const b = makeBarbell();
    b.position.set(
      (Math.random()-0.5)*spread,
      (Math.random()-0.5)*spread*0.7,
      (Math.random()-0.5)*10 - 6
    );
    b.rotation.set(Math.random()*Math.PI, Math.random()*Math.PI*2, Math.random()*Math.PI);
    b.scale.setScalar(0.5+Math.random()*0.5);
    dumbellGroup.add(b);
    objects.push({mesh:b, rx:0.001, ry:0.002+Math.random()*0.003, rz:0.002, fy:Math.random()*Math.PI*2, fspd:0.002+Math.random()*0.005, amp:0.03+Math.random()*0.06});
  }

  // Weight plates
  const plateColors = [0xAA0000, 0x330000, 0x880000, 0x660000];
  for(let i=0;i<10;i++){
    const r = 0.5+Math.random()*0.7;
    const p = makePlate(r, plateColors[i%4]);
    p.position.set(
      (Math.random()-0.5)*spread,
      (Math.random()-0.5)*spread*0.7,
      (Math.random()-0.5)*10 - 5
    );
    p.rotation.set(Math.random()*Math.PI, Math.random()*Math.PI*2, Math.random()*Math.PI*2);
    dumbellGroup.add(p);
    objects.push({mesh:p, rx:0.003+Math.random()*0.005, ry:0.002, rz:0.004+Math.random()*0.005, fy:Math.random()*Math.PI*2, fspd:0.004+Math.random()*0.007, amp:0.05+Math.random()*0.1});
  }

  // Hex plates
  for(let i=0;i<6;i++){
    const h = makeHexPlate(i%2===0?0x990000:0x1a1a1a);
    h.position.set(
      (Math.random()-0.5)*spread,
      (Math.random()-0.5)*spread*0.7,
      (Math.random()-0.5)*10 - 5
    );
    h.rotation.set(Math.random()*Math.PI, Math.random()*Math.PI*2, Math.random()*Math.PI*2);
    h.scale.setScalar(0.8+Math.random()*0.8);
    dumbellGroup.add(h);
    objects.push({mesh:h, rx:0.003, ry:0.003+Math.random()*0.005, rz:0.004, fy:Math.random()*Math.PI*2, fspd:0.005, amp:0.06});
  }

  // Kettlebells
  for(let i=0;i<5;i++){
    const k = makeKettle();
    k.position.set(
      (Math.random()-0.5)*spread,
      (Math.random()-0.5)*spread*0.7,
      (Math.random()-0.5)*8 - 5
    );
    k.rotation.set(Math.random()*Math.PI*2, Math.random()*Math.PI*2, Math.random()*Math.PI*2);
    k.scale.setScalar(0.6+Math.random()*0.6);
    dumbellGroup.add(k);
    objects.push({mesh:k, rx:0.004, ry:0.003, rz:0.005+Math.random()*0.004, fy:Math.random()*Math.PI*2, fspd:0.004, amp:0.07});
  }

  // ── LIGHTING ──
  const ambient = new THREE.AmbientLight(0xffffff, 0.15);
  scene.add(ambient);

  const redLight = new THREE.PointLight(0xDD0000, 3, 30);
  redLight.position.set(5, 5, 5);
  scene.add(redLight);

  const redLight2 = new THREE.PointLight(0xFF2200, 2, 25);
  redLight2.position.set(-8, -3, 3);
  scene.add(redLight2);

  const whiteLight = new THREE.DirectionalLight(0xffffff, 0.5);
  whiteLight.position.set(0, 10, 10);
  scene.add(whiteLight);

  const rimLight = new THREE.PointLight(0x440000, 1.5, 20);
  rimLight.position.set(0, -8, 2);
  scene.add(rimLight);

  // ── PARTICLE FIELD (floating embers) ──
  const pCount = 200;
  const pGeo = new THREE.BufferGeometry();
  const pPos = new Float32Array(pCount*3);
  const pSizes = new Float32Array(pCount);
  for(let i=0;i<pCount;i++){
    pPos[i*3]   = (Math.random()-0.5)*40;
    pPos[i*3+1] = (Math.random()-0.5)*30;
    pPos[i*3+2] = (Math.random()-0.5)*20 - 5;
    pSizes[i] = Math.random()*3+1;
  }
  pGeo.setAttribute('position', new THREE.BufferAttribute(pPos,3));
  pGeo.setAttribute('size', new THREE.BufferAttribute(pSizes,1));
  const pMat = new THREE.PointsMaterial({color:0xCC0000, size:0.06, transparent:true, opacity:0.4, sizeAttenuation:true});
  const particles = new THREE.Points(pGeo, pMat);
  scene.add(particles);

  // ── MOUSE PARALLAX ──
  let mx=0, my=0;
  document.addEventListener('mousemove', e => {
    mx = (e.clientX/window.innerWidth - 0.5) * 2;
    my = (e.clientY/window.innerHeight - 0.5) * 2;
  });

  // ── SCROLL ──
  let scrollY = 0;
  window.addEventListener('scroll', () => { scrollY = window.scrollY; });

  // ── ANIMATE ──
  const clock = new THREE.Clock();
  function animate(){
    requestAnimationFrame(animate);
    const t = clock.getElapsedTime();

    // Camera parallax
    camera.position.x += (mx * 1.5 - camera.position.x) * 0.03;
    camera.position.y += (-my * 1.0 - camera.position.y) * 0.03;
    camera.position.z = 18 - scrollY * 0.003;
    camera.lookAt(0, 0, 0);

    // Pulse lights
    redLight.intensity  = 2.5 + Math.sin(t*1.2)*0.8;
    redLight2.intensity = 1.8 + Math.cos(t*0.9)*0.6;

    // Animate each object
    objects.forEach(o => {
      o.mesh.rotation.x += o.rx;
      o.mesh.rotation.y += o.ry;
      o.mesh.rotation.z += o.rz;
      o.fy += o.fspd;
      o.mesh.position.y += Math.sin(o.fy) * o.amp * 0.01;
    });

    // Slow group rotation
    dumbellGroup.rotation.y += 0.0008;

    // Particle drift
    const pArr = pGeo.attributes.position.array;
    for(let i=0;i<pCount;i++){
      pArr[i*3+1] += 0.008;
      if(pArr[i*3+1] > 15) pArr[i*3+1] = -15;
    }
    pGeo.attributes.position.needsUpdate = true;

    renderer.render(scene, camera);
  }
  animate();

  window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth/window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
  });
})();

