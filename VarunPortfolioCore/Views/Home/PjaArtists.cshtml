document.addEventListener('keydown', e => { if (e.key === 'Escape') closeGallery(); });

// ─── THEME TOGGLE ─────────────────────────────────────────────────────────────
function toggleTheme() {
  document.body.classList.toggle('light');
  const isLight = document.body.classList.contains('light');
  document.getElementById('themeBtn').textContent = isLight ? '🌞' : '🌙';
  document.getElementById('themeBtnMobile').textContent = isLight ? '🌞' : '🌙';
}

// ─── 3D CANVAS ────────────────────────────────────────────────────────────────
const canvas = document.getElementById('art3d');
const ctx = canvas.getContext('2d');
function resizeCanvas() { canvas.width = canvas.offsetWidth; canvas.height = canvas.offsetHeight; }
resizeCanvas();
window.addEventListener('resize', resizeCanvas);

const particles = [];
const NUM = 70;
const colors = ['#c084fc', '#f472b6', '#fb923c', '#fbbf24', '#34d399', '#60a5fa'];
for (let i = 0; i < NUM; i++) {
  particles.push({
    x: Math.random(), y: Math.random(), z: Math.random(),
    vx: (Math.random() - 0.5) * 0.002, vy: (Math.random() - 0.5) * 0.002, vz: (Math.random() - 0.5) * 0.003,
    color: colors[Math.floor(Math.random() * colors.length)], size: Math.random() * 2.5 + 1
  });
}

let t = 0;
function draw() {
  const w = canvas.width, h = canvas.height;
  ctx.clearRect(0, 0, w, h);
  const isDark = !document.body.classList.contains('light');
  ctx.fillStyle = isDark ? 'rgba(18,18,26,0.3)' : 'rgba(240,236,255,0.3)';
  ctx.fillRect(0, 0, w, h);
  t += 0.01;
  particles.forEach(p => {
    p.x += p.vx + Math.sin(t + p.y * 5) * 0.0003;
    p.y += p.vy + Math.cos(t + p.x * 3) * 0.0003;
    p.z += p.vz;
    if (p.x < 0) p.x = 1; if (p.x > 1) p.x = 0;
    if (p.y < 0) p.y = 1; if (p.y > 1) p.y = 0;
    if (p.z < 0) p.z = 1; if (p.z > 1) p.z = 0;
    const perspective = 0.5 + p.z * 0.5;
    const cx = (p.x - 0.5) / perspective + 0.5;
    const cy = (p.y - 0.5) / perspective + 0.5;
    const sx = cx * w, sy = cy * h, r = p.size * perspective;
    ctx.beginPath(); ctx.arc(sx, sy, r, 0, Math.PI * 2);
    ctx.fillStyle = p.color; ctx.globalAlpha = perspective * 0.9; ctx.fill(); ctx.globalAlpha = 1;
  });
  for (let i = 0; i < particles.length; i++) {
    for (let j = i + 1; j < particles.length; j++) {
      const a = particles[i], b = particles[j];
      const pa = 0.5 + a.z * 0.5, pb = 0.5 + b.z * 0.5;
      const ax = ((a.x - 0.5) / pa + 0.5) * w, ay = ((a.y - 0.5) / pa + 0.5) * h;
      const bx = ((b.x - 0.5) / pb + 0.5) * w, by = ((b.y - 0.5) / pb + 0.5) * h;
      const dist = Math.sqrt((ax - bx) ** 2 + (ay - by) ** 2);
      if (dist < 80) {
        ctx.beginPath(); ctx.moveTo(ax, ay); ctx.lineTo(bx, by);
        ctx.strokeStyle = a.color; ctx.globalAlpha = (1 - dist / 80) * 0.25;
        ctx.lineWidth = 0.5; ctx.stroke(); ctx.globalAlpha = 1;
      }
    }
  }
  ctx.save(); ctx.globalAlpha = 0.1;
  ctx.font = 'bold ' + Math.min(w, h) * 0.38 + 'px serif';
  ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
  ctx.fillStyle = '#c084fc'; ctx.fillText('PJA', w / 2, h / 2);
  ctx.restore();
  requestAnimationFrame(draw);
}
draw();

// ─── STAGGERED SCROLL REVEAL (one by one) ────────────────────────────────────
const allRevealEls = document.querySelectorAll('.reveal, .reveal-left, .reveal-scale');

// Group elements by their parent container so siblings animate sequentially
const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const el = entry.target;
      // Find siblings in the same parent that are also reveal elements
      const parent = el.parentElement;
      const siblings = Array.from(parent.querySelectorAll('.reveal, .reveal-left, .reveal-scale'));
      const idx = siblings.indexOf(el);

      // Stagger: each element waits 120ms after the previous one
      setTimeout(() => {
        el.classList.add('visible');
      }, idx * 120);

      revealObserver.unobserve(el);
    }
  });
}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

allRevealEls.forEach(el => revealObserver.observe(el));
</script>
